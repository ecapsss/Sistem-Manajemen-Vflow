syntax = "proto3";

package cloud;

service CloudControl {
  rpc ProvisionTenant(ProvisionRequest) returns (ProvisionResponse);
}

message ProvisionRequest {
  string tenant_name = 1;
  string plan = 2;
}

message ProvisionResponse {
  string tenant_id = 1;
  string status = 2;
  string note = 3;
}
</file>

<file path="docs/provision-pattern/013-grpc-trigger/README.md">
# 013 — gRPC inbound trigger (byte-first)

Demonstrates vflow's inbound gRPC trigger landing on a workflow via
the **byte-first** payload pattern. No codegen, no .proto compile
step in vflow; all schema interpretation happens at the activity
layer via `Connector(protobuf)`.

## Files

- `workflow.yaml` — the workflow. Trigger (grpc) → Codec decode →
  Codec encode → EndTrigger.
- `proto/cloud_control.proto` — the gRPC contract (`cloud.CloudControl.ProvisionTenant`).
  Uploaded to vflow for reflection-less clients. Not strictly
  required for the runtime (adapter is schema-less).
- `test.sh` — end-to-end smoke: starts vflow-server, waits for
  both the admin registry and the kernel's WorkflowRouter to
  converge, invokes via `grpcurl`, checks the response.

## Run

Prereqs on `$PATH`: `vflow-server`, `grpcurl`, `curl`, `python3`.

```bash
./test.sh
# → [013] PASS
# → {"tenantId":"tenant-acme","status":"provisioned", ...}
```

Environment variables it honours (defaults shown):

| Var | Default |
|-----|---------|
| `VFLOW_ADMIN_PORT` | `7799` |
| `VFLOW_PIPELINE_PORT` | `7800` |
| `VFLOW_GRPC_PORT` | `50051` |

The test mkdtemps a state dir + pre-seeds
`${STATE_DIR}/grpc_server.json` with `{"enabled":true, "port":…}`
so the adapter binds on boot without an explicit
`POST /api/admin/grpc/start`.

## What the workflow exercises

Shape of `execute_wired_with_handles` in the kernel + the
byte-first path through `kernel_process::run_kernel_worker`:

```
grpcurl
  → gRPC frame over HTTP/2 (hyper h2c)
  → vflow grpc_adapter: unframe → raw protobuf bytes
  → POST /grpc/cloud.CloudControl/ProvisionTenant with
    Content-Type: application/x-protobuf (no JSON envelope)
  → vflow pipeline webhook sink (bytes pass-through)
  → kernel_process: scans graph for `trigger_body` reference,
    materialises bytes as Vec<u8>, passes as DataHandle preset
  → kernel.execute_wired_with_handles stores handle-only var
  → workflow activity `decode_request`:
      v-cel: trigger_body
      → VariableStore::get_with_bytes_fallback returns base64
      → ProtobufCodec decodes with inline schema → typed JSON
  → workflow activity `encode_response`:
      ProtobufCodec encodes typed JSON → base64 string
  → EndTrigger spv1: $.resp.encoded
  → adapter base64-decodes response body
  → adapter frames + HTTP/2 trailers (grpc-status: 0)
  → grpcurl decodes typed protobuf
```

## Business-logic extension point

The `encode_response` activity currently uses a `literal` JSON.
Real workflows would compute response fields from `$.req.*` using
`v-cel` or `vil-expr`, or insert a VRule / Function activity in
between decode and encode.

```yaml
- id: encode_response
  ...
  input_mappings:
    - target: data
      source:
        language: v-cel
        source: >
          {
            "tenant_id": "tenant-" + string(req.tenant_name),
            "status":    "provisioned",
            "note":      "plan=" + string(req.plan)
          }
```

## Related phases

- **C.1** — adapter is pure transport (DynamicMessage removed).
- **C.2** — kernel gains `execute_wired_with_handles`; webhook
  body flows in as a `DataHandle` preset.
- **C.3** (this example) — Tier 0/1 expressions resolve
  DataHandle-backed vars via `get_with_bytes_fallback`; adapter
  drops the base64+JSON envelope.
- **C.4** (future) — EndTrigger emits `DataHandle` output so the
  response side also skips the re-encode round-trip.
</file>

<file path="docs/provision-pattern/013-grpc-trigger/test.sh">
#!/usr/bin/env bash
# =============================================================================
# 013-grpc-trigger — end-to-end smoke test
# =============================================================================
#
# Boots vflow-server with the gRPC adapter enabled, provisions the
# workflow + .proto, invokes it via grpcurl, and compares against a
# fixture. Exits 0 on match.
#
# Prereqs on PATH:  vflow-server, grpcurl, curl, python3

set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

VFLOW_ADMIN_PORT="${VFLOW_ADMIN_PORT:-7799}"
VFLOW_PIPELINE_PORT="${VFLOW_PIPELINE_PORT:-7800}"
VFLOW_GRPC_PORT="${VFLOW_GRPC_PORT:-50051}"
STATE_DIR="$(mktemp -d)"
trap 'rm -rf "${STATE_DIR}"; [[ -n "${VFLOW_PID:-}" ]] && kill "${VFLOW_PID}" 2>/dev/null || true' EXIT

# Pre-seed grpc adapter state so it binds on boot (skips the
# admin `POST /grpc/start` call).
cat >"${STATE_DIR}/grpc_server.json" <<EOF
{"enabled": true, "port": ${VFLOW_GRPC_PORT}}
EOF

echo "[013] starting vflow-server"
VFLOW_PORT="${VFLOW_ADMIN_PORT}" \
VFLOW_PIPELINE_PORT="${VFLOW_PIPELINE_PORT}" \
VFLOW_WORKFLOWS_DIR="${HERE}" \
VFLOW_STATE_DIR="${STATE_DIR}" \
VIL_LOG_OFF=1 \
  vflow-server >"${STATE_DIR}/vflow.log" 2>&1 &
VFLOW_PID=$!

# Wait for admin port.
for _ in $(seq 1 30); do
    if curl -sf -o /dev/null "http://127.0.0.1:${VFLOW_ADMIN_PORT}/api/admin/health"; then
        break
    fi
    sleep 0.2
done

# Wait for the workflow webhook route to register. The admin port
# opens before the workflow watcher has scanned VFLOW_WORKFLOWS_DIR,
# so `/health` being 200 isn't enough.
registered=0
for _ in $(seq 1 100); do
    body=$(curl -sf "http://127.0.0.1:${VFLOW_ADMIN_PORT}/api/admin/health" || true)
    if printf '%s' "${body}" | grep -q '/grpc/cloud.CloudControl/ProvisionTenant'; then
        registered=1
        break
    fi
    sleep 0.2
done
if [[ "${registered}" != "1" ]]; then
    echo "[013] FAIL: workflow never registered the webhook route"
    echo "--- vflow log tail ---"
    tail -30 "${STATE_DIR}/vflow.log" 2>&1 || true
    exit 1
fi

echo "[013] uploading .proto (both for client AND server-side descriptor binding)"
curl -sf -X POST "http://127.0.0.1:${VFLOW_ADMIN_PORT}/api/admin/proto/upload" \
     -H 'X-VFlow-Proto-File: cloud_control.proto' \
     -H 'Content-Type: text/plain' \
     --data-binary "@${HERE}/proto/cloud_control.proto" >/dev/null

# Phase 1: proto_registry upload must complete BEFORE the workflow's
# first webhook hit, otherwise `body_schema: "cloud.ProvisionRequest"`
# resolves to None → kernel falls back to opaque-bytes binding →
# `trigger_body.tenant_name` returns null. Small pause to let the
# admin endpoint's write settle.
sleep 0.2

# Poll the pipeline port until the kernel's WorkflowRouter has
# picked up the route. `admin.workflows.webhook_routes()` reflects
# the ADMIN registry — the kernel watcher copies that into its own
# router on a 1s poll tick, so the two can be briefly out of sync.
# A probe that triggers "no workflow" vs. any other response tells
# us the kernel side is ready.
for _ in $(seq 1 100); do
    code=$(curl -s -o /dev/null -w '%{http_code}' \
        -H 'Content-Type: application/x-protobuf' \
        --data-binary $'\x0a\x04ping\x12\x03chk' \
        -X POST "http://127.0.0.1:${VFLOW_PIPELINE_PORT}/grpc/cloud.CloudControl/ProvisionTenant" || true)
    body_has_nowf=$(curl -s \
        -H 'Content-Type: application/x-protobuf' \
        --data-binary $'\x0a\x04ping\x12\x03chk' \
        -X POST "http://127.0.0.1:${VFLOW_PIPELINE_PORT}/grpc/cloud.CloudControl/ProvisionTenant" \
        2>/dev/null | grep -c 'no workflow for path' || true)
    if [[ "${code}" == "200" && "${body_has_nowf}" == "0" ]]; then
        break
    fi
    sleep 0.2
done

echo "[013] invoking cloud.CloudControl/ProvisionTenant via grpcurl"
set +e
out=$(grpcurl -plaintext \
    -import-path "${HERE}/proto" -proto cloud_control.proto \
    -d '{"tenant_name":"acme","plan":"pro"}' \
    "127.0.0.1:${VFLOW_GRPC_PORT}" cloud.CloudControl/ProvisionTenant 2>&1)
rc=$?
set -e
if [[ "${rc}" -ne 0 ]]; then
    echo "[013] FAIL: grpcurl rc=${rc}"
    echo "        ${out}"
    echo "--- vflow log tail ---"
    tail -30 "${STATE_DIR}/vflow.log" 2>&1 || true
    exit 1
fi

expected_tenant_id='tenant-acme'
expected_note='Phase 1 CEL typed binding + Transform encode'
got_tenant_id=$(printf '%s' "${out}" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("tenantId",""))')

if [[ "${got_tenant_id}" != "${expected_tenant_id}" ]]; then
    echo "[013] FAIL: expected tenantId=${expected_tenant_id}, got=${got_tenant_id}"
    echo "        full response: ${out}"
    echo "--- vflow log tail ---"
    tail -30 "${STATE_DIR}/vflow.log" 2>&1 || true
    exit 1
fi

echo "[013] PASS"
echo "${out}"
</file>

<file path="docs/provision-pattern/013-grpc-trigger/workflow.yaml">
version: "3.0"
metadata:
  id: grpc-provision-tenant
  name: "gRPC inbound trigger — CEL typed binding + Transform encode"
  description: |
    Demonstrates vflow's inbound gRPC trigger with Phase 1 CEL
    typed protobuf binding. No Connector activity — all data
    transformation is via `Transform` + FaaS.

    Activity layering:
      * Trigger(grpc)            — transport; declares body_schema
      * extract  (Transform)     — typed field access via CEL
                                   (trigger_body.tenant_name)
      * encode   (Transform)     — proto_encode FaaS call
      * EndTrigger              — returns base64-framed bytes

    Schema binding (Phase 1): `body_schema: "cloud.ProvisionRequest"`
    tells the kernel to resolve the descriptor from ProtoRegistry
    (populated by `POST /api/admin/proto/upload`) and install it
    on the kernel. When any CEL expression touches `trigger_body`,
    Tier 2 VM decodes the bytes via `prost_reflect::DynamicMessage`
    and binds as `VcelValue::Message`, so field access is typed:
    `trigger_body.tenant_name` returns a String.

    Smoke:
      ```bash
      VFLOW_GRPC_ENABLED=1 VFLOW_WORKFLOWS_DIR=./ vflow-server &

      curl -sX POST http://localhost:7799/api/admin/proto/upload \
           -H 'X-VFlow-Proto-File: cloud_control.proto' \
           -H 'Content-Type: text/plain' \
           --data-binary @proto/cloud_control.proto

      grpcurl -plaintext \
          -import-path ./proto -proto cloud_control.proto \
          -d '{"tenant_name":"acme","plan":"pro"}' \
          localhost:50051 cloud.CloudControl/ProvisionTenant
      ```

    Expected:
      ```json
      {"tenantId":"tenant-acme","status":"provisioned",
       "note":"Phase 1 CEL typed binding + Transform encode"}
      ```

spec:
  activities:
    - id: trigger
      activity_type: Trigger
      trigger_config:
        trigger_type: grpc
        grpc:
          service: "cloud.CloudControl"
          method: "ProvisionTenant"
          body_schema: "cloud.ProvisionRequest"
        response_framing: length_prefixed
        end_activity: respond
      output_variable: trigger_payload

    # Transform 1 — extract typed fields from the proto-bound
    # `trigger_body`. Each input_mapping's v-cel expression is
    # evaluated with the kernel's proto_bindings in scope so
    # `trigger_body.field` does typed protobuf field access. Each
    # target becomes a top-level workflow variable.
    - id: extract
      activity_type: Transform
      input_mappings:
        - target: tenant_name
          source:
            language: v-cel
            source: 'trigger_body.tenant_name'
        - target: plan
          source:
            language: v-cel
            source: 'trigger_body.plan'

    # Transform 2 — encode response via FaaS. References
    # top-level `tenant_name` directly (plain string), avoiding
    # the need for proto-bound eval inside FaaS arg evaluation.
    - id: encode_response
      activity_type: Transform
      input_mappings:
        - target: encoded
          source:
            language: v-cel
            source: >
              proto_encode(
                {
                  "name": "ProvisionResponse",
                  "fields": [
                    {"name": "tenant_id", "number": 1, "type": "string"},
                    {"name": "status",    "number": 2, "type": "string"},
                    {"name": "note",      "number": 3, "type": "string"}
                  ]
                },
                {
                  "tenant_id": "tenant-" + string(tenant_name),
                  "status":    "provisioned",
                  "note":      "Phase 1 CEL typed binding + Transform encode"
                }
              )
      output_variable: resp

    - id: respond
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        # Byte-native response (Phase 1 of the gRPC-native devplan,
        # 2026-05-03). The `encode_response` Transform's
        # `proto_encode(...)` call writes raw bytes to `resp`'s handle
        # slot via the `vil_codec_protobuf` byte sidechannel; `bytes_ref`
        # reads them with zero conversion. Replaces the legacy
        # `spv1 + encoding: base64` round-trip.
        final_response:
          language: bytes_ref
          source: 'resp'

    - id: end
      activity_type: End

  flows:
    - { id: f1, from: { node: trigger },         to: { node: extract } }
    - { id: f2, from: { node: extract },         to: { node: encode_response } }
    - { id: f3, from: { node: encode_response }, to: { node: respond } }
    - { id: f4, from: { node: respond },         to: { node: end } }
</file>

<file path="docs/provision-pattern/014-control-flow-node-matrix/workflow.yaml">
version: "3.0"
metadata:
  id: control-flow-node-matrix
  name: "P0 Control-flow node matrix"
  description: |
    Compile-time contract for public control-flow authoring nodes that were
    previously listed as example gaps. This example intentionally keeps all
    branches side-effect-free so it can stay in the default local runner.

spec:
  activities:
    - id: trigger
      activity_type: Trigger
      trigger_config:
        trigger_type: webhook
        webhook_config: { path: /examples/control-flow, method: POST }
        response_framing: length_prefixed
        end_activity: respond
      output_variable: trigger_payload

    - id: extract
      activity_type: Transform
      input_mappings:
        - target: amount
          source: { language: spv1, source: '$.trigger_payload.body.amount' }
        - target: items
          source: { language: spv1, source: '$.trigger_payload.body.items' }
        - target: approved_hint
          source: { language: v-cel, source: 'amount >= 100' }
      output_variable: extracted

    - id: wait_window
      activity_type: Timer
      description: "Timer node shape; runtime policy decides actual wait semantics."

    - id: control_passthrough
      activity_type: Control
      description: "Generic control node used when no split/join/gateway subtype is needed."

    - id: decision
      activity_type: Exclusive
      description: "XOR gateway: first matching branch wins."

    - id: fanout
      activity_type: Inclusive
      description: "OR gateway: every matching branch may continue."

    - id: retry_window
      activity_type: LoopWhile
      loop_config:
        condition: "amount > 0"
        max_iterations: 2

    - id: process_items
      activity_type: LoopForEach
      loop_config:
        collection: "$.items"
        item_variable: item
        mode: sequential
        max_iterations: 10

    - id: repeat_audit
      activity_type: LoopRepeat
      loop_config:
        repeat_count: 2
        max_iterations: 2

    - id: accepted
      activity_type: Transform
      input_mappings:
        - target: result
          source: { language: literal, source: "accepted" }
      output_variable: result

    - id: reviewed
      activity_type: Transform
      input_mappings:
        - target: result
          source: { language: literal, source: "reviewed" }
      output_variable: result

    - id: respond
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response: { language: spv1, source: '$.result' }

    - id: end
      activity_type: End

  flows:
    - { id: f01, from: { node: trigger }, to: { node: extract } }
    - { id: f02, from: { node: extract }, to: { node: wait_window } }
    - { id: f03, from: { node: wait_window }, to: { node: control_passthrough } }
    - { id: f04, from: { node: control_passthrough }, to: { node: decision } }
    - { id: f05, from: { node: decision }, to: { node: fanout }, condition: "amount >= 100", priority: 20 }
    - { id: f06, from: { node: decision }, to: { node: repeat_audit }, type: default, priority: 0 }
    - { id: f07, from: { node: fanout }, to: { node: retry_window }, condition: "amount >= 100", priority: 20 }
    - { id: f08, from: { node: fanout }, to: { node: process_items }, condition: "items != null", priority: 10 }
    - { id: f09, from: { node: retry_window }, to: { node: process_items } }
    - { id: f10, from: { node: process_items }, to: { node: accepted } }
    - { id: f11, from: { node: repeat_audit }, to: { node: reviewed } }
    - { id: f12, from: { node: accepted }, to: { node: respond } }
    - { id: f13, from: { node: reviewed }, to: { node: respond } }
    - { id: f14, from: { node: respond }, to: { node: end } }

  variables:
    - { name: trigger_payload, type: object }
    - { name: amount, type: number }
    - { name: items, type: array }
    - { name: result, type: string }
</file>

