          source:
            language: v-cel
            source: '{"customer_id": profile_context.customer_id, "email": profile_context.email, "segment": profile_context.segment}'
      output_variable: elastic_profile

    - id: update_neo4j_customer_node
      activity_type: Connector
      persistence: ssot
      connector_config:
        connector_ref: vastar.neo4j
        operation: query
      input_mappings:
        - target: cypher
          source:
            language: v-cel
            source: '"MERGE (c:Customer {customer_id: \"" + profile_context.customer_id + "\"}) SET c.email = \"" + profile_context.email + "\", c.segment = \"" + profile_context.segment + "\""'
      output_variable: neo4j_profile

    - id: write_dynamodb_projection
      activity_type: Connector
      persistence: ssot
      connector_config:
        connector_ref: vastar.dynamodb
        operation: put_item
      input_mappings:
        - target: table
          source: { language: literal, source: "customer_profile_projection" }
        - target: item
          source:
            language: v-cel
            source: '{"customer_id": profile_context.customer_id, "profile_version": profile_context.profile_version, "email": profile_context.email, "segment": profile_context.segment}'
      output_variable: dynamodb_projection

    - id: accepted_response
      activity_type: Transform
      input_mappings:
        - target: response
          source:
            language: v-cel
            source: '{"status": "projection-declared", "customer_id": profile_context.customer_id, "profile_version": profile_context.profile_version, "backend_families": ["postgres", "mysql", "yugabyte", "mongo", "elastic", "neo4j", "dynamodb"]}'
      output_variable: final_response

    - id: respond
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response: { language: spv1, source: "$.final_response" }

    - id: end
      activity_type: End

  flows:
    - { id: f01, from: { node: trigger }, to: { node: validate_profile } }
    - { id: f02, from: { node: validate_profile }, to: { node: normalize_profile } }
    - { id: f03, from: { node: normalize_profile }, to: { node: upsert_postgres_primary } }
    - { id: f04, from: { node: upsert_postgres_primary }, to: { node: mirror_mysql_read_model } }
    - { id: f05, from: { node: mirror_mysql_read_model }, to: { node: mirror_yugabyte_geo_index } }
    - { id: f06, from: { node: mirror_yugabyte_geo_index }, to: { node: write_mongo_profile_doc } }
    - { id: f07, from: { node: write_mongo_profile_doc }, to: { node: index_elastic_profile } }
    - { id: f08, from: { node: index_elastic_profile }, to: { node: update_neo4j_customer_node } }
    - { id: f09, from: { node: update_neo4j_customer_node }, to: { node: write_dynamodb_projection } }
    - { id: f10, from: { node: write_dynamodb_projection }, to: { node: accepted_response } }
    - { id: f11, from: { node: accepted_response }, to: { node: respond } }
    - { id: f12, from: { node: respond }, to: { node: end } }

  variables:
    - { name: trigger_payload, type: object }
    - { name: profile_context, type: object }
    - { name: final_response, type: object }
</file>

<file path="docs/provision-pattern/034-email-approval-notification/README.md">
# 034 Email Approval Notification

This example demonstrates the runtime-local email path:

- `email` trigger declaration for inbound IMAP-style mail events.
- V-CEL FaaS dispatch to `send_email(...)` for outbound SMTP notification.
- Local smoke mode with `VFLOW_EMAIL_TRIGGER_MOCK=1`, so the example can run
  without an external IMAP account.

Run:

```bash
bash examples-vflow/runtime-smoke/email-approval-notification-smoke.sh
```

The smoke starts a local SMTP mock, starts a real `vflow-server`, injects a
mock email trigger event, and asserts the outbound email was delivered to the
mock SMTP server.
</file>

<file path="docs/provision-pattern/034-email-approval-notification/workflow.yaml">
version: "3.0"
metadata:
  id: email-approval-notification
  name: "Email Approval Notification"
  description: |
    Runtime-local workflow that receives an email event and sends an outbound
    notification through the built-in send_email FaaS helper.
  dialect: vflow
  tags: [example, p0, email, notification]

spec:
  durability:
    enabled: true
    default_mode: eventual

  activities:
    - id: email_in
      activity_type: Trigger
      trigger_config:
        trigger_type: email
        route: /examples/email/approval
        email:
          imap_url: "localhost"
          mailbox: "INBOX"
      output_variable: email_payload

    - id: notify_ops
      activity_type: Transform
      input_mappings:
        - target: notification
          source:
            language: v-cel
            source: >
              send_email(
                "ops@example.test",
                "Approval requested: " + string(email_payload.subject),
                "From: " + string(email_payload.from) + "\n\n" + string(email_payload.body)
              )
      output_variable: notification_result

    - id: end
      activity_type: End

  flows:
    - { id: f1, from: { node: email_in }, to: { node: notify_ops } }
    - { id: f2, from: { node: notify_ops }, to: { node: end } }
</file>

<file path="docs/provision-pattern/036-timer-expression-runtime-contract/README.md">
# 036 Timer Transform Runtime Contract

Business story: a loyalty adjustment workflow calculates an order score, waits
for a short debounce window, then returns the computed routing decision. The
example exists to prove `activity_type: Transform` and `activity_type: Timer`
as runtime behavior, not only YAML compile coverage.

Covered surface:

- Webhook trigger and `EndTrigger` response.
- `Transform` activity with V-CEL mappings used by the final response.
- `Timer` activity with explicit `timer_config.delay_ms`.
- Runtime-local smoke assertion through `vflow-server`.

Run:

```bash
VFLOW_EXAMPLES_WITH_TIMER_EXPRESSION_LIVE=1 bash examples-vflow/run-all-local.sh
```

Focused:

```bash
bash examples-vflow/runtime-smoke/timer-expression-runtime-smoke.sh
```

Expected response:

```json
{
  "status": "timer_expression_ok",
  "customer_id": "cust_036",
  "score": 75,
  "priority": "standard",
  "timer_delay_ms": 25
}
```
</file>

<file path="docs/provision-pattern/036-timer-expression-runtime-contract/workflow.yaml">
version: "3.0"
metadata:
  id: timer-expression-runtime-contract
  name: "Timer Transform Runtime Contract"
  description: |
    Runtime-local contract for Transform and Timer nodes. A webhook request is
    scored with V-CEL, then delayed by a short timer before responding. This is
    intentionally local-safe so it can be part of example regression.
  dialect: vflow
  tags: [example, p1, timer, transform, runtime-contract]

spec:
  activities:
    - id: trigger
      activity_type: Trigger
      trigger_config:
        trigger_type: webhook
        route: /examples/timer-expression
        webhook_config: { path: /examples/timer-expression, method: POST }
        response_framing: length_prefixed
        end_activity: respond
      output_variable: trigger_payload

    - id: calculate_score
      activity_type: Transform
      input_mappings:
        - target: status
          source:
            language: literal
            source: "timer_expression_ok"
        - target: score
          source:
            language: v-cel
            source: 'trigger_payload.body.subtotal >= 500000 ? 75 : 25'
        - target: priority
          source:
            language: v-cel
            source: 'trigger_payload.body.subtotal >= 1000000 ? "review" : "standard"'
        - target: customer_id
          source:
            language: v-cel
            source: 'trigger_payload.body.customer_id'
        - target: timer_delay_ms
          source:
            language: v-cel
            source: '25'

    - id: debounce_window
      activity_type: Timer
      timer_config:
        delay_ms: 25

    - id: respond
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response:
          language: v-cel
          source: '{"status": "timer_expression_ok", "customer_id": customer_id, "score": score, "priority": priority, "timer_delay_ms": timer_delay_ms}'

    - id: end
      activity_type: End

  flows:
    - { id: f01, from: { node: trigger }, to: { node: calculate_score } }
    - { id: f02, from: { node: calculate_score }, to: { node: debounce_window } }
    - { id: f03, from: { node: debounce_window }, to: { node: respond } }
    - { id: f04, from: { node: respond }, to: { node: end } }

  variables:
    - { name: trigger_payload, type: object }
    - { name: customer_id, type: string }
    - { name: score, type: number }
    - { name: priority, type: string }
    - { name: timer_delay_ms, type: number }
</file>

