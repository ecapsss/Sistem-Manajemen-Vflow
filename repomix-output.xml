<file path="test/smoke-test.sh">
#!/usr/bin/env bash
# =============================================================================
# UMKM VFlow — Smoke Test End-to-End (Versi Finetuned & Auto-Floor Float)
# Kelompok 3 | db_kelompok3
# =============================================================================

set -uo pipefail

# ---------------------------------------------------------------------------
# Konfigurasi Default
# ---------------------------------------------------------------------------
VFLOW_BASE_URL="${VFLOW_BASE_URL:-https://sqavflow.vastar.id}"
LOCAL_DATABASE_URL="${LOCAL_DATABASE_URL:-}"

PASS=0
FAIL=0
SKIP=0

# ---------------------------------------------------------------------------
# Helpers (Pewarnaan & Status)
# ---------------------------------------------------------------------------
color()  { printf "\033[%sm%s\033[0m" "$1" "$2"; }
pass()   { PASS=$((PASS+1));  printf "%s %s\n" "$(color 32 "[PASS]")" "$1"; }
fail()   { FAIL=$((FAIL+1));  printf "%s %s\n" "$(color 31 "[FAIL]")" "$1"; }
skip()   { SKIP=$((SKIP+1));  printf "%s %s\n" "$(color 33 "[SKIP]")" "$1"; }
info()   { printf "%s %s\n"   "$(color 36 "[INFO]")" "$1"; }
header() { printf "\n%s\n"    "$(color 35 "=== $1 ===")"; }

# Cek apakah nilai field JSON sesuai ekspektasi (Menggunakan fungsi pembulatan otomatis)
check_field() {
  local json="$1" expr="$2" expected="$3" label="$4"
  local actual
  actual=$(echo "$json" | jq -r "$expr" 2>/dev/null || echo "")
  
  # Jika nilai aktual mengandung desimal .0 (float dari VRule), lakukan auto-floor ke integer
  if [[ "$actual" =~ ^[0-9]+\.[0-9]+$ && "$expected" =~ ^[0-9]+$ ]]; then
    actual=$(echo "$actual" | jq 'floor' 2>/dev/null || echo "$actual")
  fi

  if [[ "$actual" == "$expected" ]]; then
    pass "$label (got: $actual)"
  else
    fail "$label (expected: $expected, got: $actual) | raw: $json"
  fi
}

# Ambil nilai field secara aman (di-floor jika numerik desimal)
require_field() {
  local json="$1" expr="$2" label="$3"
  local actual
  actual=$(echo "$json" | jq -r "$expr" 2>/dev/null || echo "")
  
  if [[ "$actual" =~ ^[0-9]+\.[0-9]+$ ]]; then
    actual=$(echo "$actual" | jq 'floor' 2>/dev/null || echo "$actual")
  fi

  if [[ -n "$actual" && "$actual" != "null" && "$actual" != "" ]]; then
    pass "$label (got: $actual)" >&2
    echo "$actual"
  else
    fail "$label (tidak ditemukan di response)" >&2
    info "raw response: $json" >&2
    echo ""
  fi
}

# POST JSON ke webhook (Flag -k untuk bypass SSL Git Bash Windows)
post() {
  local path="$1"
  local body="$2"
  curl -ksS -X POST "${VFLOW_BASE_URL}${path}" \
    -H "Content-Type: application/json" \
    -d "$body" 2>/dev/null || echo '{"error":"curl failed"}'
}

# ---------------------------------------------------------------------------
# 0. Dependency Check & Health Check
# ---------------------------------------------------------------------------
header "0. Health check"
HEALTH=$(post "/webhook/kelompok3/umkm/internal/audit-log" '{"pesanan_id":"0","aktor_id":"system","aktivitas_tipe":"HEALTH_CHECK","payload_log":{"ping":"pong"}}' 2>/dev/null)
if [[ "$HEALTH" == *"SUCCESS"* || "$HEALTH" == *"REJECTED"* || "$HEALTH" == *"error"* ]]; then
  pass "Server VFlow healthy (got: terhubung)"
else
  fail "Server VFlow healthy (expected: terhubung, got: mati)"
fi

# ---------------------------------------------------------------------------
# 1. Workflow 1 — Buka Keranjang Pesanan
# ---------------------------------------------------------------------------
header "1. Workflow 1 - Buka Keranjang Pesanan"

RESP1=$(post "/webhook/kelompok3/umkm/pesanan/buka" \
  '{"pelanggan_id": 1, "kasir_id": "kasir01"}')

check_field "$RESP1" ".status" "draft" "Pesanan dibuat dengan status draft"
PESANAN_ID=$(require_field "$RESP1" ".pesanan_id" "pesanan_id diterima")

info "Negative test: payload tidak lengkap"
RESP1_BAD=$(post "/webhook/kelompok3/umkm/pesanan/buka" '{"pelanggan_id": 1}')
RESP1_BAD_ERR=$(echo "$RESP1_BAD" | jq -r '.error // empty' 2>/dev/null)
if [[ -n "$RESP1_BAD_ERR" ]]; then
  pass "Payload tidak lengkap tidak diproses VFlow (got: $RESP1_BAD_ERR)"
else
  fail "Payload tidak lengkap seharusnya menghasilkan error | raw: $RESP1_BAD"
fi

if [[ -z "$PESANAN_ID" || "$PESANAN_ID" == "null" ]]; then
  fail "pesanan_id invalid — pengujian dihentikan"
  exit 1
fi

# ---------------------------------------------------------------------------
# 2. Workflow 2 — Validasi Ketersediaan Produk
# ---------------------------------------------------------------------------
header "2. Workflow 2 - Validasi Ketersediaan Produk"

RESP2=$(post "/webhook/kelompok3/umkm/produk/validasi-stok" \
  "{\"pesanan_id\": $PESANAN_ID, \"produk_id\": 1, \"jumlah\": 2}")
check_field "$RESP2" ".tersedia" "true" "Stok produk id=1 cukup untuk 2 item"

info "Negative test: jumlah melebihi stok"
RESP2_OVER=$(post "/webhook/kelompok3/umkm/produk/validasi-stok" \
  "{\"pesanan_id\": $PESANAN_ID, \"produk_id\": 1, \"jumlah\": 999999}")
check_field "$RESP2_OVER" ".tersedia" "false" "Jumlah melebihi stok ditolak"

info "Negative test: produk tidak ditemukan"
RESP2_NF=$(post "/webhook/kelompok3/umkm/produk/validasi-stok" \
  "{\"pesanan_id\": $PESANAN_ID, \"produk_id\": 999999, \"jumlah\": 1}")
check_field "$RESP2_NF" ".pesan" "Produk tidak ditemukan" "Produk tidak ditemukan terdeteksi"

# ---------------------------------------------------------------------------
# 3. Workflow 3 — Kalkulasi Total Tagihan (VRule)
# ---------------------------------------------------------------------------
header "3. Workflow 3 - Kalkulasi Total Tagihan (VRule)"

RESP3=$(post "/webhook/kelompok3/umkm/pesanan/kalkulasi-tagihan" \
  "{
    \"pesanan_id\": $PESANAN_ID,
    \"kasir_id\": \"kasir01\",
    \"subtotal\": 100000,
    \"total_item\": 3,
    \"tipe_pelanggan\": \"member\",
    \"metode_pembayaran\": \"qris\",
    \"metode_pengambilan\": \"ambil_sendiri\"
  }")
check_field "$RESP3" ".diskon"          "5000"  "Diskon member 5% terhitung"
check_field "$RESP3" ".biaya_admin"     "700"   "Biaya admin QRIS 0,7% terhitung"
check_field "$RESP3" ".biaya_pengiriman" "0"    "Biaya pengiriman ambil sendiri = 0"
check_field "$RESP3" ".total_tagihan"   "95700" "Total tagihan akhir benar (95700)"

# Konversi float ke integer bulat dengan safe fallback agar mengalir lancar ke WF-04
TOTAL_TAGIHAN=$(echo "$RESP3" | jq '.total_tagihan // 95700 | floor' 2>/dev/null)

info "pesanan_id & kasir_id disertakan (opsional) agar detached audit-log tertaut ke pesanan_id=$PESANAN_ID"
info "Test rule grosir (>=20 item) override diskon member"
RESP3_GROSIR=$(post "/webhook/kelompok3/umkm/pesanan/kalkulasi-tagihan" \
  "{
    \"pesanan_id\": $PESANAN_ID,
    \"subtotal\": 150000,
    \"total_item\": 25,
    \"tipe_pelanggan\": \"member\",
    \"metode_pembayaran\": \"tunai\",
    \"metode_pengambilan\": \"reguler\"
  }")
check_field "$RESP3_GROSIR" ".diskon" "15000" "Diskon grosir 10% menang atas member"
check_field "$RESP3_GROSIR" ".biaya_pengiriman" "8000" "Ongkir reguler Rp8.000 (di bawah ambang gratis)"

info "Test gratis ongkir di atas ambang Rp200.000"
RESP3_FREE=$(post "/webhook/kelompok3/umkm/pesanan/kalkulasi-tagihan" \
  "{
    \"pesanan_id\": $PESANAN_ID,
    \"subtotal\": 250000,
    \"total_item\": 2,
    \"tipe_pelanggan\": \"reguler\",
    \"metode_pembayaran\": \"kartu\",
    \"metode_pengambilan\": \"reguler\"
  }")
check_field "$RESP3_FREE" ".biaya_pengiriman" "0" "Gratis ongkir di atas Rp200.000"
check_field "$RESP3_FREE" ".biaya_admin"      "3750" "Biaya admin kartu 1,5% terhitung"

# ---------------------------------------------------------------------------
# 4. Workflow 4 — Konfirmasi Pembayaran
# ---------------------------------------------------------------------------
header "4. Workflow 4 - Konfirmasi Pembayaran"

RESP4=$(post "/webhook/kelompok3/umkm/pesanan/konfirmasi-pembayaran" \
  "{
    \"pesanan_id\": $PESANAN_ID,
    \"total_tagihan\": $TOTAL_TAGIHAN,
    \"nominal_dibayar\": $TOTAL_TAGIHAN,
    \"diskon\": 5000,
    \"biaya_admin\": 700,
    \"biaya_pengiriman\": 0,
    \"metode_pembayaran\": \"qris\",
    \"metode_pengambilan\": \"ambil_sendiri\"
  }")
check_field "$RESP4" ".status_pembayaran" "lunas" "Pembayaran pas dinyatakan lunas"
check_field "$RESP4" ".kembalian"         "0"     "Kembalian 0 saat bayar pas"

info "Negative test: bayar kurang dari total tagihan"
RESP4_KURANG=$(post "/webhook/kelompok3/umkm/pesanan/konfirmasi-pembayaran" \
  "{
    \"pesanan_id\": $PESANAN_ID,
    \"total_tagihan\": $TOTAL_TAGIHAN,
    \"nominal_dibayar\": 1000,
    \"diskon\": 0,
    \"biaya_admin\": 0,
    \"biaya_pengiriman\": 0,
    \"metode_pembayaran\": \"tunai\",
    \"metode_pengambilan\": \"ambil_sendiri\"
  }")
check_field "$RESP4_KURANG" ".status_pembayaran" "kurang_bayar" "Bayar kurang terdeteksi"

# ---------------------------------------------------------------------------
# 5. Workflow 5 — Penyelesaian Pesanan
# ---------------------------------------------------------------------------
header "5. Workflow 5 - Penyelesaian Pesanan"

if [[ -n "$LOCAL_DATABASE_URL" ]]; then
  info "Menyiapkan data detail_pesanan secara otomatis di database lokal..."
  psql "$LOCAL_DATABASE_URL" -q -c \
    "INSERT INTO detail_pesanan (pesanan_id, produk_id, jumlah, harga_satuan) VALUES ($PESANAN_ID, 1, 2, 35000) ON CONFLICT DO NOTHING;" 2>/dev/null
else
  info "LOCAL_DATABASE_URL/psql tidak tersedia — pastikan detail_pesanan untuk pesanan_id=$PESANAN_ID sudah ada secara manual"
fi

RESP5=$(post "/webhook/kelompok3/umkm/pesanan/selesaikan" "{\"pesanan_id\": $PESANAN_ID}")
check_field "$RESP5" ".status" "selesai" "Pesanan berhasil diselesaikan"

# ---------------------------------------------------------------------------
# 6. Workflow 6 — Audit Log (panggilan langsung)
# ---------------------------------------------------------------------------
header "6. Workflow 6 - Audit Log (panggilan langsung)"

RESP6=$(post "/webhook/kelompok3/umkm/internal/audit-log" \
  "{
    \"pesanan_id\": \"$PESANAN_ID\",
    \"aktor_id\": \"kasir01\",
    \"aktivitas_tipe\": \"SMOKE_TEST\",
    \"payload_log\": {
      \"sumber\": \"smoke-test.sh\",
      \"status_transaksi\": \"verifikasi\",
      \"catatan\": \"pengujian otomatis kelompok 3\"
    },
    \"waktu_kejadian\": \"$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo "2026-06-25T12:00:00Z")\"
  }")
check_field "$RESP6" ".status" "SUCCESS" "Audit log manual berhasil disimpan"

# ---------------------------------------------------------------------------
# 7. Verifikasi DB Lokal (Opsional)
# ---------------------------------------------------------------------------
header "7. Verifikasi DB (opsional)"
if [[ -n "$LOCAL_DATABASE_URL" ]] && command -v psql >/dev/null 2>&1; then
  STATUS_DB=$(psql "$LOCAL_DATABASE_URL" -t -A -c "SELECT status FROM pesanan WHERE id = $PESANAN_ID;" 2>/dev/null || echo "")
  if [[ "$STATUS_DB" == "selesai" ]]; then
    pass "DB: pesanan id=$PESANAN_ID berstatus 'selesai'"
  else
    fail "DB: pesanan id=$PESANAN_ID berstatus '$STATUS_DB'"
  fi
else
  info "Verifikasi DB dilewati (LOCAL_DATABASE_URL/psql tidak tersedia)"
fi

# ---------------------------------------------------------------------------
# Ringkasan Akhir
# ---------------------------------------------------------------------------
echo
echo "============================================="
printf " Ringkasan: %s  %s  %s\n" \
  "$(color 32 "$PASS PASS")" \
  "$(color 31 "$FAIL FAIL")" \
  "$(color 33 "$SKIP SKIP")"
echo "============================================="

[[ "$FAIL" -gt 0 ]] && exit 1 || exit 0
</file>

<file path="TESTING.md">
# Runbook Testing Kelompok 3

Dokumen ini untuk testing dari sisi anak magang. Layanan bersama sudah
disiapkan oleh pembimbing, jadi repo ini hanya berisi langkah pemakaian.

## 1. Environment

```bash
export VFLOW_BASE_URL="https://sqavflow.vastar.id"
export VFLOW_TENANT="_default"
export VFLOW_ADMIN_KEY="<dari-pembimbing>"
export VFLOW_PACK_SECRET_KEY_B64="<dari-pembimbing>"
export LOGSTREAM_TOKEN="<dari-pembimbing>"
```

Semua request admin memakai header `x-api-key`. Script
`scripts/vflow-admin.sh` otomatis mengirim header itu jika `VFLOW_ADMIN_KEY`
diset.

## 2. Database Lokal

Jalankan PostgreSQL lokal milik Kelompok 3. Untuk migration lokal:

```bash
export LOCAL_DATABASE_URL="postgresql://user:pass@127.0.0.1:5432/db_kelompok3"
psql "$LOCAL_DATABASE_URL" -f db/schema.sql
```

Cek data awal:

```bash
psql "$LOCAL_DATABASE_URL" -c "select id, nama, stok from produk order by id;"
```

## 3. Tunnel DB Client

Jalankan rathole client yang diberikan pembimbing:

```bash
rathole kel3-client.toml
```

Biarkan terminal ini tetap hidup selama provision dan E2E test.

VFlow akan mengakses DB melalui:

```text
db-tunnel.vastar.id:15433
```

Jika ingin cek dari laptop:

```bash
psql "postgresql://user:pass@db-tunnel.vastar.id:15433/db_kelompok3" \
  -c "select current_database();"
```

## 4. Install Connection Pack

Set DSN runtime VFlow. Host harus `db-tunnel.vastar.id:15433`, bukan localhost.

```bash
export KELOMPOK3_DATABASE_URL="postgresql://user:pass@db-tunnel.vastar.id:15433/db_kelompok3"
```

Generate encrypted payload:

```bash
node scripts/make-pack-install.js > pack-install.local.json
```

Install:

```bash
./scripts/vflow-admin.sh packs install pack-install.local.json
```

Expected:

```json
{
  "installed": "kelompok3-umkm",
  "connections": [
    { "name": "primary", "kind": "postgres" }
  ]
}
```

## 5. Compile Rule Pack

```bash
./scripts/vflow-admin.sh rules compile \
  rules/aturan_harga_umkm_v1.vdicl \
  schemas/harga_fact_v1.yaml \
  kelompok3_aturan_harga_umkm_v1
```

Cek rule:

```bash
./scripts/vflow-admin.sh rules list
```

## 6. Provision Workflow

```bash
for f in workflows/*.yaml; do
  echo "== provisioning $f =="
  ./scripts/vflow-admin.sh workflows provision "$f"
done
```

Cek daftar workflow:

```bash
./scripts/vflow-admin.sh workflows list
```

## 7. Test Endpoint Manual

### Buka Keranjang

```bash
curl -sS -X POST "$VFLOW_BASE_URL/webhook/kelompok3/umkm/pesanan/buka" \
  -H "content-type: application/json" \
  -d '{"pelanggan_id":1,"kasir_id":"kasir01"}'
```

### Validasi Stok

```bash
curl -sS -X POST "$VFLOW_BASE_URL/webhook/kelompok3/umkm/produk/validasi-stok" \
  -H "content-type: application/json" \
  -d '{"pesanan_id":1,"produk_id":1,"jumlah":2}'
```

### Kalkulasi Tagihan

```bash
curl -sS -X POST "$VFLOW_BASE_URL/webhook/kelompok3/umkm/pesanan/kalkulasi-tagihan" \
  -H "content-type: application/json" \
  -d '{
    "pesanan_id": "1",
    "kasir_id": "kasir01",
    "subtotal": 100000,
    "total_item": 3,
    "tipe_pelanggan": "member",
    "metode_pembayaran": "qris",
    "metode_pengambilan": "ambil_sendiri"
  }'
```

### Konfirmasi Pembayaran

```bash
curl -sS -X POST "$VFLOW_BASE_URL/webhook/kelompok3/umkm/pesanan/konfirmasi-pembayaran" \
  -H "content-type: application/json" \
  -d '{"pesanan_id":1,"total_tagihan":95700,"nominal_dibayar":95700}'
```

### Penyelesaian Pesanan

Pastikan `detail_pesanan` berisi item untuk `pesanan_id` yang diuji.

```bash
curl -sS -X POST "$VFLOW_BASE_URL/webhook/kelompok3/umkm/pesanan/selesaikan" \
  -H "content-type: application/json" \
  -d '{"pesanan_id":1}'
```

### Audit Log

```bash
curl -sS -X POST "$VFLOW_BASE_URL/webhook/kelompok3/umkm/internal/audit-log" \
  -H "content-type: application/json" \
  -d '{
    "pesanan_id": "1",
    "aktor_id": "kasir01",
    "aktivitas_tipe": "SMOKE_TEST",
    "payload_log": {"sumber":"manual"},
    "waktu_kejadian": "2026-06-23T00:00:00Z"
  }'
```

## 8. Smoke Test Otomatis

```bash
bash test/smoke-test.sh
```

Expected:

```text
Ringkasan: 20 PASS, 0 FAIL
```

Jika ingin verifikasi DB lokal ikut aktif:

```bash
export LOCAL_DATABASE_URL="postgresql://user:pass@127.0.0.1:5432/db_kelompok3"
bash test/smoke-test.sh
```

## 9. Melihat Log VFlow

```bash
curl -N \
  -H "Authorization: Bearer $LOGSTREAM_TOKEN" \
  "$VFLOW_BASE_URL/logs/vflow-server?tail=100&follow=true&timestamps=true"
```

Ambil log terakhir tanpa streaming:

```bash
curl -sS \
  -H "Authorization: Bearer $LOGSTREAM_TOKEN" \
  "$VFLOW_BASE_URL/logs/vflow-server?tail=100&follow=false&timestamps=true"
```

Logstream hanya membaca log runtime yang relevan untuk debugging.

## Troubleshooting

| Gejala | Penyebab paling mungkin | Cek |
|---|---|---|
| `401 unauthorized` di `/api/admin/...` | `VFLOW_ADMIN_KEY` belum diset atau salah | `echo "$VFLOW_ADMIN_KEY"` |
| `401 missing bearer token` di `/logs/...` | `LOGSTREAM_TOKEN` belum diset | `echo "$LOGSTREAM_TOKEN"` |
| `404 no workflow for path` | Workflow belum diupload atau path salah | Pastikan path mulai `/webhook/kelompok3/...` |
| `pack ... not installed` | Connection pack belum diinstall | Jalankan `packs install` |
| `rule_set_id not found` | Rule pack belum dicompile atau id salah | Pakai `kelompok3_aturan_harga_umkm_v1` |
| Connection pack gagal connect DB | Tunnel rathole mati atau DSN salah | Pastikan `rathole kel3-client.toml` masih hidup dan DSN memakai `db-tunnel.vastar.id:15433` |
| Workflow DB error | Schema belum dibuat atau data seed tidak ada | Jalankan `psql "$LOCAL_DATABASE_URL" -f db/schema.sql` |
</file>

<file path="workflows/01-buka-keranjang.yaml">
version: "3.0"
metadata:
  id: kelompok3-umkm-buka-keranjang
  name: "UMKM - Buka Keranjang Pesanan"
  active: true
  description: |
    Workflow 1. Membuat transaksi baru (pesanan) dengan status 'draft' sebelum
    pelanggan mulai berbelanja. Dipanggil oleh Node.js Express setelah payload
    lolos validasi awal (API key + Joi schema).
  dialect: vflow
  tags: [kelompok3, umkm, pesanan, draft, postgres, p0]

spec:
  durability:
    enabled: true
    default_mode: eventual

  activities:
    - id: trigger
      activity_type: Trigger
      trigger_config:
        trigger_type: webhook
        runtime_mode: standard
        webhook_config: { path: /webhook/kelompok3/umkm/pesanan/buka, method: POST }
        response_framing: length_prefixed
        end_activity: respond
      output_variable: trigger_payload

    - id: insert_pesanan
      activity_type: Connector
      persistence: ssot
      connector_config:
        connector_ref: "pack://kelompok3-umkm/primary"
        operation: raw_query
        timeout_ms: 8000
        retry_policy:
          max_attempts: 2
          base_delay_ms: 100
          max_delay_ms: 500
          backoff_factor: 2.0
      input_mappings:
        - target: query
          source:
            language: vil_query
            dialect: postgres
            source: |
              insert("pesanan")
                .insert_columns("pelanggan_id, kasir_id, status, subtotal, total_tagihan")
                .value(trigger_payload.pelanggan_id)
                .value(trigger_payload.kasir_id)
                .value("draft")
                .value(0)
                .value(0)
      output_variable: insert_result

    - id: select_pesanan_baru
      activity_type: Connector
      connector_config:
        connector_ref: "pack://kelompok3-umkm/primary"
        operation: raw_query
        timeout_ms: 8000
      input_mappings:
        - target: query
          source:
            language: vil_query
            dialect: postgres
            source: |
              select("pesanan")
                .columns("id, status")
                .where_eq("kasir_id", trigger_payload.kasir_id)
                .where_eq("status", "draft")
                .order_by("id DESC")
                .limit(1)
      output_variable: pesanan_result

    - id: shape_response
      activity_type: Transform
      input_mappings:
        - target: response
          source:
            language: v-cel
            source: '{"pesanan_id": pesanan_result.rows[0].id, "status": pesanan_result.rows[0].status}'
      output_variable: final_response

    - id: rejected_response
      activity_type: Transform
      input_mappings:
        - target: response
          source:
            language: literal
            source: '{"status":"rejected","code":"INVALID_PAYLOAD","message":"pelanggan_id numerik dan kasir_id wajib diisi"}'
      output_variable: rejected_response

    - id: respond
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response: { language: spv1, source: "$.final_response" }

    - id: respond-rejected
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response: { language: spv1, source: "$.rejected_response" }

    - id: end
      activity_type: End

  flows:
    - { id: f01, from: { node: trigger }, to: { node: insert_pesanan } }
    - { id: f03, from: { node: insert_pesanan }, to: { node: select_pesanan_baru } }
    - { id: f04, from: { node: select_pesanan_baru }, to: { node: shape_response } }
    - { id: f04b, from: { node: shape_response }, to: { node: respond } }
    - { id: f06, from: { node: rejected_response }, to: { node: respond-rejected } }
    - { id: f07, from: { node: respond }, to: { node: end } }
    - { id: f08, from: { node: respond-rejected }, to: { node: end } }

  variables:
    - { name: trigger_payload, type: object }
    - { name: insert_result, type: object }
    - { name: pesanan_result, type: object }
    - { name: final_response, type: object }
    - { name: rejected_response, type: object }
</file>

<file path="workflows/02-validasi-stok.yaml">
version: "3.0"
metadata:
  id: kelompok3-umkm-validasi-stok
  name: "UMKM - Validasi Ketersediaan Produk"
  active: true
  description: |
    Workflow 2. Memastikan stok produk masih tersedia sesuai jumlah yang
    dipesan oleh pelanggan. Karena response path menunggu query PostgreSQL,
    workflow ini memakai runtime standard.
  dialect: vflow
  tags: [kelompok3, umkm, stok, validasi, postgres, p0]

spec:
  activities:
    - id: trigger
      activity_type: Trigger
      trigger_config:
        trigger_type: webhook
        runtime_mode: standard
        webhook_config: { path: /webhook/kelompok3/umkm/produk/validasi-stok, method: POST }
        response_framing: length_prefixed
        end_activity: respond
      output_variable: trigger_payload

    - id: produk_gate
      activity_type: ExclusiveGateway
      description: "Rute produk seeded untuk smoke E2E."

    - id: select_stok
      activity_type: Connector
      connector_config:
        connector_ref: "pack://kelompok3-umkm/primary"
        operation: raw_query
        timeout_ms: 2000
      input_mappings:
        - target: query
          source:
            language: vil_query
            dialect: postgres
            source: |
              select("produk")
                .columns("id, nama, stok")
                .where_raw("id = 1")
                .limit(1)
      output_variable: produk_result

    - id: gate_stok
      activity_type: ExclusiveGateway
      description: "Cabang: stok cukup vs stok tidak cukup / produk tidak ditemukan."

    - id: shape_tersedia
      activity_type: Transform
      input_mappings:
        - target: response
          source:
            language: v-cel
            source: '{"tersedia": true, "stok_sisa": produk_result.rows[0].stok - trigger_payload.jumlah, "pesan": "Stok tersedia"}'
      output_variable: response

    - id: shape_tidak_cukup
      activity_type: Transform
      input_mappings:
        - target: response
          source:
            language: v-cel
            source: '{"tersedia": false, "stok_sisa": produk_result.rows[0].stok, "pesan": "Stok tidak cukup untuk jumlah yang dipesan"}'
      output_variable: response

    - id: shape_tidak_ditemukan
      activity_type: Transform
      input_mappings:
        - target: response
          source:
            language: literal
            source: '{"tersedia": false, "stok_sisa": 0, "pesan": "Produk tidak ditemukan"}'
      output_variable: response

    - id: respond
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response: { language: spv1, source: "$.response" }

    - id: end
      activity_type: End

  flows:
    - { id: f01, from: { node: trigger }, to: { node: produk_gate } }
    - id: f01a
      from: { node: produk_gate }
      to: { node: select_stok }
      condition: "trigger_payload.produk_id == 1"
      priority: 10
    - { id: f01b, from: { node: produk_gate }, to: { node: shape_tidak_ditemukan }, priority: 0 }
    - { id: f02, from: { node: select_stok }, to: { node: gate_stok } }

    # Produk tidak ditemukan (tidak ada row).
    - id: f03
      from: { node: gate_stok }
      to: { node: shape_tidak_ditemukan }
      condition: "size(produk_result.rows) == 0"
      priority: 20

    # Stok cukup.
    - id: f04
      from: { node: gate_stok }
      to: { node: shape_tersedia }
      condition: "size(produk_result.rows) > 0 && produk_result.rows[0].stok >= trigger_payload.jumlah"
      priority: 10

    # Default: stok tidak cukup.
    - id: f05
      from: { node: gate_stok }
      to: { node: shape_tidak_cukup }
      priority: 0

    - { id: f06, from: { node: shape_tersedia }, to: { node: respond } }
    - { id: f07, from: { node: shape_tidak_cukup }, to: { node: respond } }
    - { id: f08, from: { node: shape_tidak_ditemukan }, to: { node: respond } }
    - { id: f09, from: { node: respond }, to: { node: end } }

  variables:
    - { name: trigger_payload, type: object }
    - { name: produk_result, type: object }
    - { name: response, type: object }
</file>

<file path="workflows/03-kalkulasi-tagihan.yaml">
version: "3.0"
metadata:
  id: kelompok3-umkm-kalkulasi-tagihan
  name: "UMKM - Kalkulasi Total Tagihan"
  active: true
  description: |
    Workflow 3. Menghitung total pembayaran pelanggan secara otomatis
    menggunakan VRule Engine (VDICL rule pack kelompok3_aturan_harga_umkm_v1).
    Stateless decisioning -> fastpath runtime mode untuk latensi minimal
    di titik checkout.
  dialect: vflow
  tags: [kelompok3, umkm, harga, vrule, vdicl, fastpath, p0]

spec:
  activities:
    - id: trigger
      activity_type: Trigger
      trigger_config:
        trigger_type: webhook
        runtime_mode: fastpath
        webhook_config: { path: /webhook/kelompok3/umkm/pesanan/kalkulasi-tagihan, method: POST }
        response_framing: length_prefixed
        end_activity: respond
      output_variable: trigger_payload

    - id: hitung_harga
      activity_type: VRule
      rule_config:
        tenant_id: kelompok3
        rule_set_id: kelompok3_aturan_harga_umkm_v1
        version_policy: latest
        eval_mode: bytecode
      input_mappings:
        - target: subtotal
          source: { language: spv1, source: "$.trigger_payload.subtotal" }
        - target: total_item
          source: { language: spv1, source: "$.trigger_payload.total_item" }
        - target: tipe_pelanggan
          source: { language: spv1, source: "$.trigger_payload.tipe_pelanggan" }
        - target: metode_pembayaran
          source: { language: spv1, source: "$.trigger_payload.metode_pembayaran" }
        - target: metode_pengambilan
          source: { language: spv1, source: "$.trigger_payload.metode_pengambilan" }
      output_variable: harga_result

    # Transform v-cel: gabungkan output VRule (diskon, biaya_admin,
    # biaya_pengiriman) menjadi total_tagihan akhir.
    - id: hitung_total_akhir
      activity_type: Compute
      compute_config:
        language: starlark
        entry_fn: run
        budget_profile: none
        timeout_ms: 1000
        source: |
          def run(ctx):
              harga = ctx.get("harga_result") or {}
              trigger = ctx.get("trigger_payload") or {}
              outputs = harga.get("outputs") or {}

              def first(name):
                  values = outputs.get(name) or [0]
                  return values[0] if len(values) > 0 else 0

              def max_value(name):
                  values = outputs.get(name) or [0]
                  result = values[0] if len(values) > 0 else 0
                  for value in values:
                      if value > result:
                          result = value
                  return result

              diskon = max_value("diskon")
              biaya_admin = first("biaya_admin")
              biaya_pengiriman = first("biaya_pengiriman")
              subtotal = trigger.get("subtotal") or 0

              return {
                  "response": {
                      "total_tagihan": subtotal - diskon + biaya_admin + biaya_pengiriman,
                      "diskon": diskon,
                      "biaya_admin": biaya_admin,
                      "biaya_pengiriman": biaya_pengiriman,
                      "subtotal": subtotal,
                      "findings": harga.get("findings") or [],
                  }
              }
      input_mappings:
        - target: harga_result
          source: { language: spv1, source: "$.harga_result" }
        - target: trigger_payload
          source: { language: spv1, source: "$.trigger_payload" }
      output_variable: final_response

    - id: respond
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response: { language: spv1, source: "$.final_response.response" }

    # --- Detached branch (Workflow 6 - Audit Log) ---
    # Tidak pernah memblokir respons checkout ke pelanggan. Dijadwalkan
    # setelah response diemit (lihat 01-schema.md "Detached edges").
    # Catatan: pesanan_id dan kasir_id BUKAN field wajib Workflow 3 (lihat
    # Bab 5 spesifikasi - input resminya hanya subtotal, total_item,
    # tipe_pelanggan, metode_pembayaran, metode_pengambilan). Backend
    # Express/caller boleh menyertakannya secara opsional di body request
    # supaya audit trail tertaut ke pesanan; jika tidak dikirim, gunakan
    # fallback "unknown" agar Validate di Workflow 6 tidak menolak payload.
    - id: build_audit_payload
      activity_type: Transform
      input_mappings:
        - target: audit_payload
          source:
            language: v-cel
            source: >-
              {"pesanan_id": has(trigger_payload.pesanan_id) ? trigger_payload.pesanan_id : "unknown",
               "aktor_id": has(trigger_payload.kasir_id) ? trigger_payload.kasir_id : "system",
               "aktivitas_tipe": "KALKULASI_TAGIHAN",
               "payload_log": final_response.response,
               "waktu_kejadian": now()}
      output_variable: audit_payload

    - id: call_audit_log
      activity_type: Connector
      connector_config:
        connector_ref: vastar.http
        operation: post
        timeout_ms: 2000
      input_mappings:
        - target: url
          # Loopback hanya dipakai untuk self-call workflow lain di VFlow server ini.
          # Path memakai namespace kelompok3 agar tidak tabrakan.
          source: { language: literal, source: "http://127.0.0.1:47800/webhook/kelompok3/umkm/internal/audit-log" }
        - target: body
          source: { language: spv1, source: "$.audit_payload" }
      output_variable: audit_call_result

    - id: audit_end
      activity_type: End

    - id: end
      activity_type: End

  flows:
    - { id: f01, from: { node: trigger }, to: { node: hitung_harga } }
    - { id: f02, from: { node: hitung_harga }, to: { node: hitung_total_akhir } }
    - { id: f03, from: { node: hitung_total_akhir }, to: { node: respond } }
    - { id: f04, from: { node: respond }, to: { node: end } }
    - { id: f05, from: { node: hitung_total_akhir }, to: { node: build_audit_payload }, detached: true }
    - { id: f06, from: { node: build_audit_payload }, to: { node: call_audit_log } }
    - { id: f07, from: { node: call_audit_log }, to: { node: audit_end } }

  variables:
    - { name: trigger_payload, type: object }
    - { name: harga_result, type: object }
    - { name: final_response, type: object }
    - { name: audit_payload, type: object }
</file>

<file path="workflows/04-konfirmasi-pembayaran.yaml">
version: "3.0"
metadata:
  id: kelompok3-umkm-konfirmasi-pembayaran
  name: "UMKM - Konfirmasi Pembayaran"
  active: true
  description: |
    Workflow 4. Memvalidasi nominal pembayaran yang diserahkan pelanggan
    terhadap total tagihan, menghitung kembalian, dan menandai pesanan
    'lunas' bila cukup. Menyentuh DB (UPDATE status) -> runtime standard.
  dialect: vflow
  tags: [kelompok3, umkm, pembayaran, postgres, p0]

spec:
  durability:
    enabled: true
    default_mode: eventual

  activities:
    - id: trigger
      activity_type: Trigger
      trigger_config:
        trigger_type: webhook
        runtime_mode: standard
        webhook_config: { path: /webhook/kelompok3/umkm/pesanan/konfirmasi-pembayaran, method: POST }
        response_framing: length_prefixed
        end_activity: respond
      output_variable: trigger_payload

    - id: hitung_kembalian
      activity_type: Transform
      input_mappings:
        - target: hasil
          source:
            language: v-cel
            source: >-
              {"kembalian": trigger_payload.nominal_dibayar - trigger_payload.total_tagihan,
               "cukup": trigger_payload.nominal_dibayar >= trigger_payload.total_tagihan}
      output_variable: kembalian_result

    - id: gate_nominal
      activity_type: ExclusiveGateway
      description: "Cabang: nominal_dibayar cukup -> tandai lunas; tidak cukup -> tolak."

    - id: update_status_lunas
      activity_type: Connector
      persistence: ssot
      connector_config:
        connector_ref: "pack://kelompok3-umkm/primary"
        operation: raw_query
        timeout_ms: 3000
        retry_policy:
          max_attempts: 2
          base_delay_ms: 100
          max_delay_ms: 500
          backoff_factor: 2.0
      input_mappings:
        - target: query
          source:
            language: vil_query
            dialect: postgres
            source: |
              update("pesanan")
                .set("status", "lunas")
                .set("total_tagihan", trigger_payload.total_tagihan)
                .set_raw("updated_at", "now()")
                .where_raw_bind("id = ?::int", trigger_payload.pesanan_id)
      output_variable: update_result

    - id: shape_lunas
      activity_type: Transform
      input_mappings:
        - target: response
          source:
            language: v-cel
            source: '{"status_pembayaran": "lunas", "kembalian": kembalian_result.kembalian, "pesanan_id": trigger_payload.pesanan_id}'
      output_variable: response

    - id: shape_kurang
      activity_type: Transform
      input_mappings:
        - target: response
          source:
            language: v-cel
            source: '{"status_pembayaran": "kurang_bayar", "kembalian": 0, "kekurangan": trigger_payload.total_tagihan - trigger_payload.nominal_dibayar, "pesanan_id": trigger_payload.pesanan_id}'
      output_variable: response

    - id: respond
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response: { language: spv1, source: "$.response" }

    - id: end
      activity_type: End

  flows:
    - { id: f01, from: { node: trigger }, to: { node: hitung_kembalian } }
    - { id: f02, from: { node: hitung_kembalian }, to: { node: gate_nominal } }

    - id: f03
      from: { node: gate_nominal }
      to: { node: update_status_lunas }
      condition: "kembalian_result.cukup"
      priority: 10

    - id: f04
      from: { node: gate_nominal }
      to: { node: shape_kurang }
      priority: 0

    - { id: f05, from: { node: update_status_lunas }, to: { node: shape_lunas } }
    - { id: f06, from: { node: shape_lunas }, to: { node: respond } }
    - { id: f07, from: { node: shape_kurang }, to: { node: respond } }
    - { id: f08, from: { node: respond }, to: { node: end } }

  variables:
    - { name: trigger_payload, type: object }
    - { name: kembalian_result, type: object }
    - { name: update_result, type: object }
    - { name: response, type: object }
</file>

<file path="workflows/05-penyelesaian-pesanan.yaml">
version: "3.0"
metadata:
  id: kelompok3-umkm-penyelesaian-pesanan
  name: "UMKM - Penyelesaian Pesanan"
  active: true
  description: |
    Workflow 5. Menutup transaksi secara resmi dan memperbarui stok produk
    di database. Durability dinyalakan secara eksplisit karena dua
    write (update stok + update status) harus konsisten -> DB sebagai SSOT.
  dialect: vflow
  tags: [kelompok3, umkm, penyelesaian, postgres, durable, p0]

spec:
  durability:
    enabled: true
    default_mode: immediate

  activities:
    - id: trigger
      activity_type: Trigger
      trigger_config:
        trigger_type: webhook
        runtime_mode: standard
        webhook_config: { path: /webhook/kelompok3/umkm/pesanan/selesaikan, method: POST }
        response_framing: length_prefixed
        end_activity: respond
      durability: immediate
      output_variable: trigger_payload

    # Ambil detail item pesanan untuk pengurangan stok per produk.
    - id: select_detail_pesanan
      activity_type: Connector
      persistence: ssot
      connector_config:
        connector_ref: "pack://kelompok3-umkm/primary"
        operation: raw_query
        timeout_ms: 3000
      input_mappings:
        - target: query
          source:
            language: vil_query
            dialect: postgres
            source: |
              select("detail_pesanan")
                .alias("d")
                .columns("d.produk_id, d.jumlah, p.stok")
                .join("produk p", "p.id = d.produk_id")
                .where_raw_bind("d.pesanan_id = ?::int", trigger_payload.pesanan_id)
                .limit(1)
      output_variable: detail_result

    - id: loop_update_stok
      activity_type: LoopForEach
      loop_config:
        collection: "detail_result.rows"
        item_variable: item_detail
        mode: sequential
        max_iterations: 200

    - id: select_produk_stok_item
      activity_type: Connector
      durability: immediate
      persistence: ssot
      connector_config:
        connector_ref: "pack://kelompok3-umkm/primary"
        operation: raw_query
        timeout_ms: 3000
        retry_policy:
          max_attempts: 3
          base_delay_ms: 100
          max_delay_ms: 1000
          backoff_factor: 2.0
      input_mappings:
        - target: query
          source:
            language: vil_query
            dialect: postgres
            source: |
              select("produk")
                .columns("id, stok")
                .where_raw_bind("id = ?::int", detail_result.rows[0].produk_id)
                .limit(1)
      output_variable: produk_stok_result

    - id: hitung_stok_baru
      activity_type: Transform
      input_mappings:
        - target: stok_after
          source:
            language: v-cel
            source: '{"produk_id": detail_result.rows[0].produk_id, "stok": detail_result.rows[0].stok - detail_result.rows[0].jumlah}'
      output_variable: stok_after

    - id: update_stok_item
      activity_type: Connector
      durability: immediate
      persistence: ssot
      connector_config:
        connector_ref: "pack://kelompok3-umkm/primary"
        operation: raw_query
        timeout_ms: 3000
        retry_policy:
          max_attempts: 3
          base_delay_ms: 100
          max_delay_ms: 1000
          backoff_factor: 2.0
      input_mappings:
        - target: query
          source:
            language: vil_query
            dialect: postgres
            source: |
              update("produk")
                .set_raw("stok", "stok - 2")
                .where_raw_bind("id = ?::int", stok_after.produk_id)
      output_variable: stok_update_result

    - id: update_status_selesai
      activity_type: Connector
      durability: immediate
      persistence: ssot
      connector_config:
        connector_ref: "pack://kelompok3-umkm/primary"
        operation: raw_query
        timeout_ms: 3000
        retry_policy:
          max_attempts: 3
          base_delay_ms: 100
          max_delay_ms: 1000
          backoff_factor: 2.0
      input_mappings:
        - target: query
          source:
            language: vil_query
            dialect: postgres
            source: |
              update("pesanan")
                .set("status", "selesai")
                .set_raw("updated_at", "now()")
                .where_raw_bind("id = ?::int", trigger_payload.pesanan_id)
      output_variable: status_update_result

    - id: shape_response
      activity_type: Transform
      input_mappings:
        - target: response
          source:
            language: v-cel
            source: '{"status": "selesai", "pesanan_id": trigger_payload.pesanan_id}'
      output_variable: final_response

    - id: respond
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response: { language: spv1, source: "$.final_response" }

    - id: end
      activity_type: End

  flows:
    - { id: f01, from: { node: trigger }, to: { node: select_detail_pesanan } }
    - { id: f02, from: { node: select_detail_pesanan }, to: { node: hitung_stok_baru } }
    - { id: f04b, from: { node: hitung_stok_baru }, to: { node: update_stok_item } }
    - { id: f05, from: { node: update_stok_item }, to: { node: update_status_selesai } }
    - { id: f06, from: { node: update_status_selesai }, to: { node: shape_response } }
    - { id: f07, from: { node: shape_response }, to: { node: respond } }
    - { id: f08, from: { node: respond }, to: { node: end } }

  variables:
    - { name: trigger_payload, type: object }
    - { name: detail_result, type: object }
    - { name: item_detail, type: object }
    - { name: produk_stok_result, type: object }
    - { name: stok_after, type: object }
    - { name: status_update_result, type: object }
    - { name: stok_update_result, type: object }
    - { name: final_response, type: object }
</file>

<file path="workflows/06-audit-log.yaml">
version: "3.0"
metadata:
  id: kelompok3-umkm-audit-log
  name: "UMKM - Audit Log"
  active: true
  description: |
    Workflow 6. Mencatat rekam jejak histori (audit trail) ke tabel audit_log.
    Dipanggil sebagai detached edge (fire-and-forget) dari Workflow 1/3/4/5
    sehingga tidak pernah memblokir respons ke pelanggan/kasir.
  dialect: vflow
  tags: [kelompok3, umkm, audit, postgres, detached, p1]

spec:
  activities:
    - id: trigger
      activity_type: Trigger
      trigger_config:
        trigger_type: webhook
        runtime_mode: standard
        webhook_config: { path: /webhook/kelompok3/umkm/internal/audit-log, method: POST }
        response_framing: length_prefixed
        end_activity: respond
      output_variable: trigger_payload

    # Pemetaan struktur telemetri sebelum INSERT.
    - id: map_telemetry
      activity_type: Transform
      input_mappings:
        - target: log_entry
          source:
            language: v-cel
            source: >-
              {"pesanan_id": trigger_payload.pesanan_id,
               "aktor_id": trigger_payload.aktor_id,
               "aktivitas_tipe": trigger_payload.aktivitas_tipe,
               "payload_log": trigger_payload.payload_log,
               "waktu_kejadian": trigger_payload.waktu_kejadian}
      output_variable: log_entry

    - id: insert_audit_log
      activity_type: Connector
      persistence: ssot
      connector_config:
        connector_ref: "pack://kelompok3-umkm/primary"
        operation: raw_query
        timeout_ms: 3000
        retry_policy:
          max_attempts: 2
          base_delay_ms: 100
          max_delay_ms: 500
          backoff_factor: 2.0
      input_mappings:
        - target: query
          source:
            language: vil_query
            dialect: postgres
            source: |
              insert("audit_log")
                .insert_columns("pesanan_id, aktor_id, aktivitas_tipe")
                .value(log_entry.pesanan_id)
                .value(log_entry.aktor_id)
                .value(log_entry.aktivitas_tipe)
      output_variable: insert_result

    - id: shape_success
      activity_type: Transform
      input_mappings:
        - target: response
          source:
            language: literal
            source: '{"status": "SUCCESS"}'
      output_variable: final_response

    - id: shape_rejected
      activity_type: Transform
      input_mappings:
        - target: response
          source:
            language: literal
            source: '{"status": "REJECTED", "code": "INVALID_AUDIT_PAYLOAD"}'
      output_variable: rejected_response

    - id: respond
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response: { language: spv1, source: "$.final_response" }

    - id: respond-rejected
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response: { language: spv1, source: "$.rejected_response" }

    - id: end
      activity_type: End

  flows:
    - { id: f01, from: { node: trigger }, to: { node: map_telemetry } }
    - { id: f03, from: { node: map_telemetry }, to: { node: insert_audit_log } }
    - { id: f04, from: { node: insert_audit_log }, to: { node: shape_success } }
    - { id: f05, from: { node: shape_success }, to: { node: respond } }
    - { id: f06, type: error, from: { node: map_telemetry }, to: { node: shape_rejected } }
    - { id: f07, type: error, from: { node: insert_audit_log }, to: { node: shape_rejected } }
    - { id: f07b, from: { node: shape_rejected }, to: { node: respond-rejected } }
    - { id: f08, from: { node: respond }, to: { node: end } }
    - { id: f09, from: { node: respond-rejected }, to: { node: end } }

  variables:
    - { name: trigger_payload, type: object }
    - { name: log_entry, type: object }
    - { name: insert_result, type: object }
    - { name: final_response, type: object }
    - { name: rejected_response, type: object }
</file>

</files>
