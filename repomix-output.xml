        runtime_mode: fastpath
        grpc:
          service: "examples.RiskScoring"
          method: "ScoreRisk"
          body_schema: "examples.RiskRequest"
        response_framing: length_prefixed
        end_activity: respond
      output_variable: trigger_payload

    - id: score_risk
      activity_type: VRule
      rule_config:
        tenant_id: examples
        rule_set_id: fastpath_risk_v1
        version_policy: latest
      # Input mappings stay in the YAML for documentation + JSON-path
      # fallback. On fastpath gRPC the proto-field tier serves these
      # without entering the v-cel VM, AND V-Rule's proto-native
      # input dispatch consumes the cached `DynamicMessage` directly
      # from the `ProtoHandle` (skipping the JSON intermediate
      # entirely).
      input_mappings:
        - target: amount
          source: { language: v-cel, source: 'trigger_body.amount' }
        - target: country
          source: { language: v-cel, source: 'trigger_body.country' }
        - target: card_bin
          source: { language: v-cel, source: 'trigger_body.card_bin' }
        - target: merchant_category
          source: { language: v-cel, source: 'trigger_body.merchant_category' }
        - target: customer_tier
          source: { language: v-cel, source: 'trigger_body.customer_tier' }
        - target: velocity_1h
          source: { language: v-cel, source: 'trigger_body.velocity_1h' }
      output_variable: risk_result

    - id: respond
      activity_type: EndTrigger
