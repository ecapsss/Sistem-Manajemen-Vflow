version: "3.0"
metadata:
  id: marketplace-fulfillment-saga
  name: "Marketplace Fulfillment Saga"
  description: |
    Marketplace checkout saga. Reserves inventory, captures payment through a
    child workflow, quotes shipment, joins the work, and commits shipment. Any
    failure enters an ErrorBoundary and returns an operator-facing
    compensation-required response.
  dialect: vflow
  tags: [example, p0, marketplace, saga, parallel, subworkflow, compensation]

spec:
  durability:
    enabled: true
    default_mode: eventual
    compensation_timeout_ms: 30000

  activities:
    - id: trigger
      activity_type: Trigger
      trigger_config:
        trigger_type: webhook
        route: /examples/marketplace/checkout
        webhook_config: { path: /examples/marketplace/checkout, method: POST }
        response_framing: length_prefixed
        end_activity: respond-success
      output_variable: trigger_payload

    - id: normalize_checkout
      activity_type: Transform
      input_mappings:
        - target: checkout
          source:
            language: v-cel
            source: '{"checkout_id": trigger_payload.body.checkout_id, "idempotency_key": trigger_payload.body.idempotency_key, "customer_id": trigger_payload.body.customer_id, "amount": trigger_payload.body.amount, "currency": trigger_payload.body.currency, "items": trigger_payload.body.items, "ship_to": trigger_payload.body.ship_to}'
      output_variable: checkout_context

    - id: fork_fulfillment
      activity_type: Parallel
      description: "Reserve inventory, capture payment, and quote shipping concurrently."

    - id: reserve_inventory
      activity_type: Connector
      persistence: ssot
      connector_config:
        connector_ref: vastar.http
        operation: post
        timeout_ms: 3000
      input_mappings:
        - target: url
          source: { language: literal, source: "http://127.0.0.1:18022/inventory/reserve" }
        - target: body
          source:
            language: v-cel
            source: '{"checkout_id": checkout_context.checkout_id, "items": checkout_context.items, "idempotency_key": checkout_context.idempotency_key}'
      output_variable: inventory_reservation
      compensation:
        connector_ref: vastar.http
        operation: post
        input_mappings:
          - target: url
            source: { language: literal, source: "http://127.0.0.1:18022/inventory/release" }
          - target: body
            source:
              language: v-cel
              source: '{"checkout_id": checkout_context.checkout_id, "reservation": inventory_reservation}'

    - id: capture_payment_child
      activity_type: SubWorkflow
      persistence: ssot
      sub_workflow_config:
        workflow_ref: marketplace-payment-capture-child
        timeout_ms: 5000
        input_strategy: mapped
      input_mappings:
        - target: checkout_id
          source: { language: spv1, source: "$.checkout_context.checkout_id" }
        - target: idempotency_key
          source: { language: spv1, source: "$.checkout_context.idempotency_key" }
        - target: amount
          source: { language: spv1, source: "$.checkout_context.amount" }
        - target: currency
          source: { language: spv1, source: "$.checkout_context.currency" }
      output_variable: payment_capture

    - id: quote_shipment
      activity_type: Connector
      persistence: ssot
      connector_config:
        connector_ref: vastar.http
        operation: post
        timeout_ms: 3000
      input_mappings:
        - target: url
          source: { language: literal, source: "http://127.0.0.1:18022/shipping/quote" }
        - target: body
          source:
            language: v-cel
            source: '{"checkout_id": checkout_context.checkout_id, "items": checkout_context.items, "ship_to": checkout_context.ship_to}'
      output_variable: shipment_quote

    - id: join_fulfillment
      activity_type: Join
      description: "Wait for inventory, payment, and shipment quote."
      output_variable: fulfillment_inputs

    - id: commit_shipment
      activity_type: Connector
      persistence: ssot
      connector_config:
        connector_ref: vastar.http
        operation: post
        timeout_ms: 3000
      input_mappings:
        - target: url
          source: { language: literal, source: "http://127.0.0.1:18022/shipping/commit" }
        - target: body
          source:
            language: v-cel
            source: '{"checkout_id": checkout_context.checkout_id, "reservation": inventory_reservation, "payment": payment_capture, "quote": shipment_quote}'
      output_variable: shipment_commit
      compensation:
        connector_ref: vastar.http
        operation: post
        input_mappings:
          - target: url
            source: { language: literal, source: "http://127.0.0.1:18022/shipping/cancel" }
          - target: body
            source:
              language: v-cel
              source: '{"checkout_id": checkout_context.checkout_id, "shipment": shipment_commit}'

    - id: success_response
      activity_type: Transform
      input_mappings:
        - target: response
          source:
            language: v-cel
            source: '{"status": "fulfilled", "checkout_id": checkout_context.checkout_id, "inventory": inventory_reservation, "payment": payment_capture, "shipment": shipment_commit}'
      output_variable: success_response

    - id: fulfillment_error_boundary
      activity_type: ErrorBoundary
      description: "Operator-visible saga failure boundary before compensation response."

    - id: backoff_before_failure_response
      activity_type: Timer
      description: "Short backoff hook; runtime policy decides actual wait behavior."

    - id: failure_response
      activity_type: Transform
      input_mappings:
        - target: response
          source:
            language: v-cel
            source: '{"status": "compensation_required", "checkout_id": checkout_context.checkout_id, "reason": "fulfillment_side_effect_failed"}'
      output_variable: failure_response

    - id: respond-success
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response: { language: spv1, source: "$.success_response" }

    - id: respond-failure
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response: { language: spv1, source: "$.failure_response" }

    - id: end
      activity_type: End

  flows:
    - { id: f01, from: { node: trigger }, to: { node: normalize_checkout } }
    - { id: f02, from: { node: normalize_checkout }, to: { node: fork_fulfillment } }
    - { id: f03, from: { node: fork_fulfillment }, to: { node: reserve_inventory } }
    - { id: f04, from: { node: fork_fulfillment }, to: { node: capture_payment_child } }
    - { id: f05, from: { node: fork_fulfillment }, to: { node: quote_shipment } }
    - { id: f06, from: { node: reserve_inventory }, to: { node: join_fulfillment } }
    - { id: f07, from: { node: capture_payment_child }, to: { node: join_fulfillment } }
    - { id: f08, from: { node: quote_shipment }, to: { node: join_fulfillment } }
    - { id: f09, from: { node: join_fulfillment }, to: { node: commit_shipment } }
    - { id: f10, from: { node: commit_shipment }, to: { node: success_response } }
    - { id: f11, from: { node: success_response }, to: { node: respond-success } }
    - { id: f12, type: error, from: { node: reserve_inventory }, to: { node: fulfillment_error_boundary } }
    - { id: f13, type: error, from: { node: capture_payment_child }, to: { node: fulfillment_error_boundary } }
    - { id: f14, type: error, from: { node: quote_shipment }, to: { node: fulfillment_error_boundary } }
    - { id: f15, type: error, from: { node: commit_shipment }, to: { node: fulfillment_error_boundary } }
    - { id: f16, from: { node: fulfillment_error_boundary }, to: { node: backoff_before_failure_response } }
    - { id: f17, from: { node: backoff_before_failure_response }, to: { node: failure_response } }
    - { id: f18, from: { node: failure_response }, to: { node: respond-failure } }
    - { id: f19, from: { node: respond-success }, to: { node: end } }
    - { id: f20, from: { node: respond-failure }, to: { node: end } }

  variables:
    - { name: trigger_payload, type: object }
    - { name: checkout_context, type: object }
    - { name: inventory_reservation, type: object }
    - { name: payment_capture, type: object }
    - { name: shipment_quote, type: object }
    - { name: shipment_commit, type: object }
</file>

<file path="docs/provision-pattern/023-human-approval-event-gateway/README.md">
# 023 Human Approval Event Gateway

High-value order review example for runtime-local operator flows.

It demonstrates:

- webhook intake and payload validation
- HumanTask parking for manual approval
- EventGateway wait/resume from an external fraud signal
- Signal cancellation branch for rejected fraud signals
- statestore-facing `persistence: ssot` annotations for operator decisions

The live smoke starts a real `vflow-server`, sends a high-value order, completes
the parked HumanTask through the admin API, fires the fraud-cleared event, and
asserts the final HTTP response.

```bash
VFLOW_EXAMPLES_WITH_HUMAN_APPROVAL_LIVE=1 \
  bash examples-vflow/run-all-local.sh
```
</file>

<file path="docs/provision-pattern/023-human-approval-event-gateway/workflow.yaml">
version: "3.0"
metadata:
  id: human-approval-event-gateway
  name: "Human Approval Event Gateway"
  description: |
    High-value order review workflow. The runtime accepts an order, validates
    and classifies it, parks on a HumanTask for an operator approval, waits for
    an external fraud-cleared/fraud-rejected event, then returns the final
    decision. This is user-runtime functionality and does not involve
    vflow-cloud.
  dialect: vflow
  tags: [example, p0, humantask, eventgateway, signal, operator]

spec:
  durability:
    enabled: true
    default_mode: eventual

  activities:
    - id: trigger
      activity_type: Trigger
      trigger_config:
        trigger_type: webhook
        route: /examples/approval/orders
        webhook_config: { path: /examples/approval/orders, method: POST }
        response_framing: length_prefixed
        end_activity: respond-approved
      output_variable: trigger_payload

    - id: validate_order
      activity_type: Validate
      validate_config:
        input: "$.trigger_payload.body"
        schema:
          required: [order_id, customer_id, currency, amount_cents, items]
          properties:
            order_id: { type: string, min_length: 3 }
            customer_id: { type: string, min_length: 3 }
            currency: { type: string, min_length: 3, max_length: 3 }
            amount_cents: { type: integer, min: 1 }
            items: { type: array, min: 1 }
      output_variable: validated_order

    - id: classify_order
      activity_type: Transform
      input_mappings:
        - target: order
          source:
            language: v-cel
            source: '{"order_id": trigger_payload.body.order_id, "customer_id": trigger_payload.body.customer_id, "currency": trigger_payload.body.currency, "amount_cents": trigger_payload.body.amount_cents, "items": trigger_payload.body.items, "approval_required": trigger_payload.body.amount_cents >= 5000000, "risk_reason": trigger_payload.body.amount_cents >= 5000000 ? "high_value_order" : "standard_order"}'
      output_variable: order_context

    - id: manual_review_gate
      activity_type: Exclusive
      description: "Only high-value orders park for operator approval."

    - id: approval
      activity_type: HumanTask
      persistence: ssot
      human_task_config:
        task_type: order-approval
        assignee: ops_approver
        candidate_groups: [risk_ops]
        title: "High-value order approval"
        description: "Review customer, amount, and items before allowing fulfillment."
        form_ref: order-approval-form-v1
        priority: 90
      input_mappings:
        - target: order
          source: { language: spv1, source: "$.order_context" }
      output_variable: approval_result

    - id: wait_fraud_event
      activity_type: EventGateway
      persistence: ssot
      event_gateway_config:
        await: [fraud-cleared, fraud-rejected]
        timeout_ms: 60000

    - id: cancel_rejected_order
      activity_type: Signal
      persistence: skip
      signal_config:
        signal_type: cancel
        name: fraud-rejected-order

    - id: approved_response
      activity_type: Transform
      input_mappings:
        - target: response
          source:
            language: v-cel
            source: '{"status": "approved", "order_id": order_context.order_id, "approval": approval_result.output, "fraud_event": "fraud-cleared", "operator_note": "HumanTask complete plus EventGateway resume"}'
      output_variable: approved_response

    - id: straight_through_response
      activity_type: Transform
      input_mappings:
        - target: response
          source:
            language: v-cel
            source: '{"status": "accepted", "order_id": order_context.order_id, "reason": order_context.risk_reason}'
      output_variable: straight_through_response

    - id: rejected_response
      activity_type: Transform
      input_mappings:
        - target: response
          source:
            language: v-cel
            source: '{"status": "rejected", "order_id": order_context.order_id, "reason": "operator_rejected_or_timed_out", "error": _error}'
      output_variable: rejected_response

    - id: invalid_response
      activity_type: Transform
      input_mappings:
        - target: response
          source:
            language: literal
            source: '{"status":"invalid","reason":"order payload failed validation"}'
      output_variable: invalid_response

    - id: respond-approved
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response: { language: spv1, source: "$.approved_response" }

    - id: respond-straight-through
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response: { language: spv1, source: "$.straight_through_response" }

    - id: respond-rejected
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response: { language: spv1, source: "$.rejected_response" }

    - id: respond-invalid
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response: { language: spv1, source: "$.invalid_response" }

    - id: end
      activity_type: End

  flows:
    - { id: f01, from: { node: trigger }, to: { node: validate_order } }
    - { id: f02, from: { node: validate_order }, to: { node: classify_order } }
    - { id: f03, from: { node: classify_order }, to: { node: manual_review_gate } }
    - { id: f04, from: { node: manual_review_gate }, to: { node: approval }, condition: "order_context.amount_cents >= 5000000", priority: 10 }
    - { id: f05, from: { node: manual_review_gate }, to: { node: straight_through_response }, type: default, priority: 100 }
    - { id: f06, from: { node: approval }, to: { node: wait_fraud_event } }
    - { id: f07, from: { node: wait_fraud_event }, to: { node: cancel_rejected_order }, condition: '_last_output.event == "fraud-rejected"', priority: 10 }
    - { id: f08, from: { node: wait_fraud_event }, to: { node: approved_response }, condition: '_last_output.event == "fraud-cleared"', priority: 20 }
    - { id: f09, type: error, from: { node: approval }, to: { node: rejected_response } }
    - { id: f10, type: error, from: { node: validate_order }, to: { node: invalid_response } }
    - { id: f11, from: { node: approved_response }, to: { node: respond-approved } }
    - { id: f12, from: { node: straight_through_response }, to: { node: respond-straight-through } }
    - { id: f13, from: { node: rejected_response }, to: { node: respond-rejected } }
    - { id: f14, from: { node: invalid_response }, to: { node: respond-invalid } }
    - { id: f15, from: { node: respond-approved }, to: { node: end } }
    - { id: f16, from: { node: respond-straight-through }, to: { node: end } }
    - { id: f17, from: { node: respond-rejected }, to: { node: end } }
    - { id: f18, from: { node: respond-invalid }, to: { node: end } }

  variables:
    - { name: trigger_payload, type: object }
    - { name: order_context, type: object }
    - { name: approval_result, type: object }
    - { name: approved_response, type: object }
</file>

<file path="docs/provision-pattern/024-runtime-artifacts-wasm-native-sidecar/README.md">
# 024 Runtime Artifacts WASM Native Sidecar

Pricing example for runtime-local artifact controls and handler invocation.

It demonstrates:

- `Function`/WASM invocation shape
- `NativeCode` invocation shape
- real `Sidecar` invocation through a registered Python sidecar process
- artifact registration remains runtime-local and is not proxied by
  vflow-cloud

The live smoke registers the sidecar against a real `vflow-server`, triggers
the pricing workflow, and asserts the sidecar-computed final price. WASM/native
plugin binaries remain optional because portable real binaries are handled by
the runtime-console artifact E2E harness.

```bash
VFLOW_EXAMPLES_WITH_ARTIFACTS_LIVE=1 \
  bash examples-vflow/run-all-local.sh
```
</file>

<file path="docs/provision-pattern/024-runtime-artifacts-wasm-native-sidecar/sidecars/pricing_sidecar.py">
#!/usr/bin/env python3
import json
import sys


def quote(body):
    items = body.get("items") or []
    subtotal = 0
    for item in items:
        price = int(item.get("unit_price_cents") or 0)
        qty = int(item.get("qty") or 0)
        subtotal += price * qty

    currency = body.get("currency") or "IDR"
    order_id = body.get("order_id") or "unknown"
    discount = 0
    if subtotal >= 1_000_000:
        discount = int(subtotal * 0.05)
    tax = int((subtotal - discount) * 0.11)
    final_price = subtotal - discount + tax
    return {
        "status": "quoted",
        "order_id": order_id,
        "currency": currency,
        "subtotal_cents": subtotal,
        "discount_cents": discount,
        "tax_cents": tax,
        "final_price_cents": final_price,
        "_sidecar": "pricing_sidecar",
    }


def main():
    for raw in sys.stdin:
        line = raw.strip()
        if not line:
            continue
        try:
            msg = json.loads(line)
            body = msg.get("body") or msg
            if not isinstance(body, dict):
                body = {}
            sys.stdout.write(json.dumps(quote(body), sort_keys=True) + "\n")
            sys.stdout.flush()
        except Exception as exc:
            sys.stdout.write(json.dumps({"error": str(exc)}) + "\n")
            sys.stdout.flush()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
</file>

