<file path="docs/provision-pattern/007-3tier-statestore/workflow.yaml">
version: "3.0"
metadata:
  id: 3tier-checkout
  name: "StateStore Snapshot Policy — Checkout Pipeline"
  # VFlow-exclusive: workflow-level snapshot policy + per-step durability.
  # Runtime backend choice is configured by the runtime deployment
  # (redb/TiKV/etc.); workflow YAML declares semantics, not a DB topology.
  durability:
    mode: external-io-snapshot
    storage:
      compression: zstd
      encryption: aes256
spec:
  activities:
    - id: trigger
      activity_type: Trigger
      trigger_config:
        trigger_type: webhook
        webhook_config: { path: /api/checkout, method: POST }
        response_framing: length_prefixed
        end_activity: respond
      output_variable: trigger_payload
    - id: cart_lookup
      activity_type: Transform
      durability: non_durable
      input_mappings:
        - target: cart
          source: { language: v-cel, source: 'trigger_payload.body.cart' }
        - target: user_id
          source: { language: v-cel, source: 'trigger_payload.body.user_id' }
      output_variable: cart_data
    - id: price_calc
      activity_type: VRule
      durability: eventual
      rule_config:
        rule_set_id: pricing_rules_v1
      input_mappings:
        - target: items
          source: { language: v-cel, source: 'cart_data.cart.items' }
        - target: user_tier
          source: { language: v-cel, source: 'trigger_payload.body.membership_tier' }
      output_variable: pricing
    - id: payment_reserve
      activity_type: Connector
      durability: immediate
      persistence: ssot         # P4.20: payment reservation is authoritative; store receipt
      connector_config:
        connector_ref: vastar.http
        operation: post
      input_mappings:
        - target: url
          source: { language: literal, source: "http://payment-gw/api/reserve" }
        - target: body
          source: { language: v-cel, source: '{"user_id": cart_data.user_id, "amount": pricing.total}' }
      output_variable: payment_result
    - id: respond
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response: { language: v-cel, source: '{"order_id": payment_result.order_id, "total": pricing.total, "status": "reserved"}' }
    - id: end
      activity_type: End
  flows:
    - { id: f1, from: { node: trigger }, to: { node: cart_lookup } }
    - { id: f2, from: { node: cart_lookup }, to: { node: price_calc } }
    - { id: f3, from: { node: price_calc }, to: { node: payment_reserve } }
    - { id: f4, from: { node: payment_reserve }, to: { node: respond } }
    - { id: f5, from: { node: respond }, to: { node: end } }
</file>

<file path="docs/provision-pattern/008-immediate-durability/workflow.yaml">
version: "3.0"
metadata:
  id: payment-transfer
  name: "Journal-State Durability — Bank Transfer"
  # VFlow-exclusive: journal-state workflow mode + immediate critical steps.
  # Runtime resolves the AES key via VFLOW_STATE_ENCRYPTION_KEY
  # (VilVault/Vault/KMS/env/file handoff), not from the workflow YAML itself.
  durability:
    mode: journal-state
    retention:
      l2: 24h
    storage:
      compression: zstd
      encryption: aes256
spec:
  activities:
    - id: trigger
      activity_type: Trigger
      trigger_config:
        trigger_type: webhook
        webhook_config: { path: /api/transfer, method: POST }
        response_framing: length_prefixed
        end_activity: respond
      output_variable: trigger_payload
    - id: validate_input
      activity_type: Transform
      durability: non_durable
      input_mappings:
        - target: from_account
          source: { language: v-cel, source: 'trigger_payload.body.from_account' }
        - target: to_account
          source: { language: v-cel, source: 'trigger_payload.body.to_account' }
        - target: amount
          source: { language: v-cel, source: 'trigger_payload.body.amount' }
        - target: is_valid
          source: { language: v-cel, source: 'trigger_payload.body.amount > 0 && trigger_payload.body.from_account != trigger_payload.body.to_account' }
      output_variable: validated
    - id: debit_source
      activity_type: Connector
      durability: immediate
      persistence: full         # P4.20: debit is critical + irreversible — persist input+output
      connector_config:
        connector_ref: vastar.http
        operation: post
      input_mappings:
        - target: url
          source: { language: literal, source: "http://core-banking/api/debit" }
        - target: body
          source: { language: v-cel, source: '{"account": validated.from_account, "amount": validated.amount}' }
      output_variable: debit_result
    - id: credit_destination
      activity_type: Connector
      durability: immediate
      persistence: full         # P4.20: credit side of transfer — persist input+output
      connector_config:
        connector_ref: vastar.http
        operation: post
      input_mappings:
        - target: url
          source: { language: literal, source: "http://core-banking/api/credit" }
        - target: body
          source: { language: v-cel, source: '{"account": validated.to_account, "amount": validated.amount}' }
      output_variable: credit_result
    - id: audit_log
      activity_type: Connector
      durability: immediate
      persistence: ssot         # P4.20: audit receipt — stored verbatim, no re-call on resume
      connector_config:
        connector_ref: vastar.http
        operation: post
      input_mappings:
        - target: url
          source: { language: literal, source: "http://audit-service/api/log" }
        - target: body
          source: { language: v-cel, source: '{"from": validated.from_account, "to": validated.to_account, "amount": validated.amount, "debit_ref": debit_result.ref_id, "credit_ref": credit_result.ref_id}' }
      output_variable: audit_result
    - id: respond
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response: { language: v-cel, source: '{"status": "completed", "debit_ref": debit_result.ref_id, "credit_ref": credit_result.ref_id, "audit_id": audit_result.audit_id}' }
    - id: end
      activity_type: End
  flows:
    - { id: f1, from: { node: trigger }, to: { node: validate_input } }
    - { id: f2, from: { node: validate_input }, to: { node: debit_source } }
    - { id: f3, from: { node: debit_source }, to: { node: credit_destination } }
    - { id: f4, from: { node: credit_destination }, to: { node: audit_log } }
    - { id: f5, from: { node: audit_log }, to: { node: respond } }
    - { id: f6, from: { node: respond }, to: { node: end } }
</file>

<file path="docs/provision-pattern/009-rate-limit-policy/workflow.yaml">
version: "3.0"
metadata:
  id: rate-limited-api
  name: "Rate Limit + Policy Enforcement"
  # VFlow-exclusive: per-workflow rate limiting and connector policy
  # rate_limit: max requests per window
  # policy.deny_connectors: block certain connector refs at runtime
  # policy.allowed_hosts: restrict outbound HTTP destinations
spec:
  rate_limit:
    max_requests: 100
    window_seconds: 60
    burst: 20
    key: "{tenant_id}"
  policy:
    deny_connectors:
      - vastar.shell
      - vastar.file_write
    allowed_hosts:
      - "api.internal.example.com"
      - "payment-gw.example.com"
    max_execution_ms: 5000
  activities:
    - id: trigger
      activity_type: Trigger
      trigger_config:
        trigger_type: webhook
        webhook_config: { path: /api/protected/data, method: GET }
        response_framing: length_prefixed
        end_activity: respond
      output_variable: trigger_payload
    - id: fetch_data
      activity_type: Connector
      persistence: ssot         # P4.20: cached GET response; skip re-fetch on resurrection
      connector_config:
        connector_ref: vastar.http
        operation: get
      input_mappings:
        - target: url
          source: { language: v-cel, source: '"https://api.internal.example.com/v1/data/" + trigger_payload.query.id' }
        - target: headers
          source: { language: v-cel, source: '{"Authorization": "Bearer " + trigger_payload.headers["x-api-key"]}' }
      output_variable: api_data
    - id: sanitize
      activity_type: Transform
      input_mappings:
        - target: result
          source: { language: v-cel, source: '{"data": api_data.body, "served_at": timestamp(now), "rate_remaining": __vflow_rate.remaining}' }
      output_variable: sanitized
    - id: respond
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response: { language: v-cel, source: 'sanitized.result' }
    - id: end
      activity_type: End
  flows:
    - { id: f1, from: { node: trigger }, to: { node: fetch_data } }
    - { id: f2, from: { node: fetch_data }, to: { node: sanitize } }
    - { id: f3, from: { node: sanitize }, to: { node: respond } }
    - { id: f4, from: { node: respond }, to: { node: end } }
</file>

<file path="docs/provision-pattern/010-fixedwidth-parser/workflow.yaml">
version: "3.0"
metadata:
  id: slik-parser
  name: "Fixed-Width Parser — SLIK/OJK Banking Format"
  # VFlow-exclusive: vil_parse_fixedwidth connector for legacy banking formats
  # SLIK = Sistem Layanan Informasi Keuangan (OJK credit bureau)
  # Fixed-width records: positions define fields, no delimiters
spec:
  activities:
    - id: trigger
      activity_type: Trigger
      trigger_config:
        trigger_type: webhook
        webhook_config: { path: /api/slik/parse, method: POST }
        response_framing: length_prefixed
        end_activity: respond
      output_variable: trigger_payload
    - id: parse_header
      activity_type: Connector
      persistence: skip         # P4.20: pure deterministic parse — recompute free
      connector_config:
        connector_ref: vastar.parse_fixedwidth
        operation: parse
      input_mappings:
        - target: raw_data
          source: { language: v-cel, source: 'trigger_payload.body.raw_content' }
        - target: schema
          source:
            language: literal
            source:
              record_type: header
              encoding: "ISO-8859-1"
              fields:
                - { name: record_type, start: 0, length: 2, type: string }
                - { name: report_date, start: 2, length: 8, type: date, format: "YYYYMMDD" }
                - { name: bank_code, start: 10, length: 4, type: string }
                - { name: total_records, start: 14, length: 6, type: integer, padding: zero }
      output_variable: header
    - id: parse_detail
      activity_type: Connector
      persistence: skip         # P4.20: pure deterministic batch parse — recompute free
      connector_config:
        connector_ref: vastar.parse_fixedwidth
        operation: parse_batch
      input_mappings:
        - target: raw_data
          source: { language: v-cel, source: 'trigger_payload.body.raw_content' }
        - target: skip_lines
          source: { language: literal, source: 1 }
        - target: schema
          source:
            language: literal
            source:
              record_type: detail
              encoding: "ISO-8859-1"
              fields:
                - { name: record_type, start: 0, length: 2, type: string }
                - { name: nik, start: 2, length: 16, type: string }
                - { name: full_name, start: 18, length: 50, type: string, trim: right }
                - { name: credit_limit, start: 68, length: 15, type: decimal, scale: 2, padding: zero }
                - { name: outstanding, start: 83, length: 15, type: decimal, scale: 2, padding: zero }
                - { name: collectability, start: 98, length: 1, type: integer }
                - { name: last_payment_date, start: 99, length: 8, type: date, format: "YYYYMMDD" }
      output_variable: details
    - id: enrich
      activity_type: Transform
      input_mappings:
        - target: report
          source:
            language: v-cel
            source: |
              {
                "header": header,
                "record_count": details.records.size(),
                "total_outstanding": details.records.map(r, r.outstanding).sum(),
                "high_risk": details.records.filter(r, r.collectability >= 3),
                "parsed_at": timestamp(now)
              }
      output_variable: enriched
    - id: respond
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response: { language: v-cel, source: 'enriched.report' }
    - id: end
      activity_type: End
  flows:
    - { id: f1, from: { node: trigger }, to: { node: parse_header } }
    - { id: f2, from: { node: parse_header }, to: { node: parse_detail } }
    - { id: f3, from: { node: parse_detail }, to: { node: enrich } }
    - { id: f4, from: { node: enrich }, to: { node: respond } }
    - { id: f5, from: { node: respond }, to: { node: end } }
</file>

<file path="docs/provision-pattern/011-vil-query-sql/workflow.yaml">
version: "3.0"
metadata:
  id: vil-query-demo
  name: "VilQuery SQL input-mapping — pre-compiled at upload time"
  description: |
    Demonstrates the `vil_query` input-mapping language. The compiler
    parses the DSL at provision time (`vflow_compiler::vil_query_compile`)
    into a SQL string + param_refs list, stores both in the VWFC blob, and
    at runtime the kernel resolves the refs against the VariableStore and
    hands `{operation: "raw_query", sql, params, _vil_query: true}` to the
    sqlx connector (bypasses the raw-SQL policy warning because the query
    went through the parameterised compiler).

    Start with VFLOW_SQLITE_PATH set so the sqlite connector registers:
      VFLOW_SQLITE_PATH=/tmp/vflow-demo.db cargo run --release
    then upload this yaml via POST /api/admin/workflow/upload.

spec:
  activities:
    - id: trigger
      activity_type: Trigger
      trigger_config:
        trigger_type: webhook
        webhook_config: { path: /api/users/find, method: POST }
        response_framing: length_prefixed
        end_activity: respond
      output_variable: trigger_payload

    - id: query
      activity_type: Connector
      persistence: ssot         # P4.20: SELECT result — cache on resurrection to skip DB round-trip
      connector_config:
        connector_ref: vastar.db.sqlite
        operation: raw_query
        timeout_ms: 5000
      input_mappings:
        - source:
            language: vil_query
            # Pre-compiled at upload: ordering + limit bind literally,
            # `trigger_payload.body.id` becomes a parameter ref that the
            # kernel resolves per request.
            source: |
              select("users")
                .columns("id, name, email")
                .where_eq("id", trigger_payload.body.id)
                .limit(1)
      output_variable: result

    - id: respond
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response:
          language: spv1
          source: '$.result'

    - id: end
      activity_type: End

  flows:
    - { id: f1, from: { node: trigger },  to: { node: query } }
    - { id: f2, from: { node: query },    to: { node: respond } }
    - { id: f3, from: { node: respond },  to: { node: end } }
</file>

