<file path="docs/provision-pattern/047-fastpath-vrule-risk-scoring/README.md">
# 047 Fastpath V-Rule Risk Scoring

Stateless benchmark workflow for V-Rule on `spec.runtime.mode: fastpath`.

The route accepts a payment risk payload, evaluates a preloaded VDICL rule pack
on the synchronous response path, and returns the rule decision directly from
`EndTrigger`. It is intended for blackbox webhook benchmark runs, not admin or
provision endpoint benchmarking.

```bash
SCENARIOS="047-fastpath-vrule-risk-scoring" \
TOOLS="vastar wrk" \
MODE=requests \
REQUESTS=5000 \
bash benchmark-vflow/run-primary.sh
```
</file>

<file path="docs/provision-pattern/047-fastpath-vrule-risk-scoring/rules/fastpath_risk_v1.vdicl">
schema_ref:
  path: "../schemas/fastpath_risk_fact_v1.yaml"
  namespace: "examples.fastpath"
  entity: "fastpath_risk_fact"
  version: 1
hit_policy: PRIORITY
rules:
  - id: "FASTPATH_BLOCKED_MERCHANT"
    priority: 0
    enabled: true
    description: "Reject explicitly blocked merchant categories."
    when: "merchant_category == 'blocked'"
    then:
      - kind: EMIT
        severity: ERROR
        code: "FASTPATH_BLOCKED_MERCHANT"
        field: "merchant_category"
        msg: "Merchant category is blocked"
      - kind: ADD_SCORE
        score_delta: 100
      - kind: SET_DECISION
        decision: REJECT

  - id: "FASTPATH_CROSS_BORDER_HIGH_VALUE"
    priority: 10
    enabled: true
    description: "Step up cross-border or high-value payments."
    when: "amount >= 20000000 OR country != 'ID' OR velocity_1h >= 5"
    then:
      - kind: EMIT
        severity: WARN
        code: "FASTPATH_STEP_UP"
        field: "amount"
        msg: "Step-up authentication required"
      - kind: ADD_SCORE
        score_delta: 45
      - kind: SET_DECISION
        decision: CHALLENGE_MFA

  - id: "FASTPATH_GOLD_APPROVE"
    priority: 50
    enabled: true
    description: "Approve gold-tier customers under the step-up threshold."
    when: "customer_tier == 'gold' AND amount >= 1"
    then:
      - kind: ADD_SCORE
        score_delta: 0
      - kind: SET_DECISION
        decision: ACCEPT

  - id: "FASTPATH_STANDARD_APPROVE"
    priority: 100
    enabled: true
    description: "Approve standard low-risk payments."
    when: "amount >= 1"
    then:
      - kind: ADD_SCORE
        score_delta: 0
      - kind: SET_DECISION
        decision: ACCEPT
</file>

<file path="docs/provision-pattern/047-fastpath-vrule-risk-scoring/schemas/fastpath_risk_fact_v1.yaml">
version: 1
namespace: examples.fastpath
schema_version: 1
domain: payments
entity: fastpath_risk_fact

# Phase 2 gRPC-native input. When the same compiled pack is evaluated
# against an inbound `examples.RiskRequest` protobuf message (e.g.
# workflow `060-standard-vrule-risk-scoring-grpc`), V-Rule walks the
# message's field-number chains directly — no JSON intermediate.
# Webhook workflows (047, 049, 052, ...) continue to evaluate via the
# JSON path; the proto binding is harmless metadata for them.
bind_proto: examples.RiskRequest

# Phase 3 gRPC-native output. When V-Rule's proto-input path runs AND
# this descriptor is in the proto registry, the rule output (decision,
# total_score, findings_count) is encoded into an
# `examples.RiskResponse` message and written to the V-Rule activity's
# output variable as raw protobuf bytes. EndTrigger `bytes_ref` reads
# them with zero conversion. Workflows that emit JSON output (049 etc.)
# ignore this — the proto encode only fires on the proto path.
output_proto_schema: examples.RiskResponse

fields:
  - path: amount
    scalar: F64
    nullable: false
  - path: country
    scalar: SYM
    nullable: false
  - path: card_bin
    scalar: SYM
    nullable: false
  - path: merchant_category
    scalar: SYM
    nullable: false
  - path: customer_tier
    scalar: SYM
    nullable: false
  - path: velocity_1h
    scalar: F64
    nullable: false
</file>

<file path="docs/provision-pattern/047-fastpath-vrule-risk-scoring/workflow.yaml">
version: "3.0"
metadata:
  id: fastpath-vrule-risk-scoring
  name: "Fastpath V-Rule Risk Scoring"
  description: "Stateless VDICL/V-Rule decision path optimized for webhook response latency."

spec:
  activities:
    - id: trigger
      activity_type: Trigger
      trigger_config:
        trigger_type: webhook
        runtime_mode: fastpath
        webhook_config: { path: /bench/fastpath/vrule-risk, method: POST }
        response_framing: length_prefixed
      output_variable: trigger_payload

    - id: score_risk
      activity_type: VRule
      rule_config:
