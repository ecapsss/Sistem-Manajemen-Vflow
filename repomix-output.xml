                "schedule": trigger_payload._schedule,
                "fired_at": trigger_payload._fired_at
              }
      output_variable: capture_result

    - id: end
      activity_type: End

  flows:
    - { id: f01, from: { node: cron_tick }, to: { node: notify_capture } }
    - { id: f02, from: { node: notify_capture }, to: { node: end } }

  variables:
    - { name: trigger_payload, type: object }
    - { name: capture_result, type: object }
</file>

<file path="docs/provision-pattern/046-runtime-console-action-blackbox/README.md">
# 046 Runtime Console Action Blackbox

Real-server operator smoke for runtime-local execution actions:

- route pause/resume affects real HTTP dispatch
- `Retry` re-triggers persisted input against the current active version
- `Replay` pins persisted input to an explicit workflow version
- `Cancel` writes the durable marker and asks the live kernel to stop at a
  cooperative node/IO boundary

Run:

```bash
bash examples-vflow/runtime-smoke/runtime-console-action-blackbox-smoke.sh
```

Expected signal:

```text
RUNTIME_CONSOLE_ACTION_BLACKBOX_SMOKE_OK
```
</file>

<file path="docs/provision-pattern/046-runtime-console-action-blackbox/workflow-cancel.yaml">
version: "3.0"
metadata:
  id: runtime-console-action-cancel
  name: "Runtime Console Action Cancel Target"
  description: |
    Long-running local-safe workflow used by the runtime console action
    blackbox smoke to prove cooperative cancellation reaches a live kernel.
  dialect: vflow
  tags: [example, runtime-console, cancel]

spec:
  activities:
    - id: trigger
      activity_type: Trigger
      trigger_config:
        trigger_type: webhook
        route: /examples/runtime-console-actions-cancel
        webhook_config: { path: /examples/runtime-console-actions-cancel, method: POST }
        response_framing: length_prefixed
        end_activity: respond
      output_variable: trigger_payload

    - id: remember_request
      activity_type: Transform
      input_mappings:
        - target: request_id
          source: { language: v-cel, source: 'trigger_payload.body.request_id' }

    - id: long_wait_boundary
      activity_type: Timer
      timer_config:
        delay_ms: 30000

    - id: respond
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response:
          language: v-cel
          source: '{"status": "unexpected_completed_without_cancel", "request_id": request_id}'

    - id: end
      activity_type: End

  flows:
    - { id: f01, from: { node: trigger }, to: { node: remember_request } }
    - { id: f02, from: { node: remember_request }, to: { node: long_wait_boundary } }
    - { id: f03, from: { node: long_wait_boundary }, to: { node: respond } }
    - { id: f04, from: { node: respond }, to: { node: end } }

  variables:
    - { name: trigger_payload, type: object }
    - { name: request_id, type: string }
</file>

