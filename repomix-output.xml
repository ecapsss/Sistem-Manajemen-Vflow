          source: { language: literal, source: "bench.ai_gateway.audit.fastpath.detached.v1" }
        - target: payload
          source: { language: spv1, source: "$.audit_record" }
      output_variable: audit_publish

    - id: end
      activity_type: End

    - id: audit_end
      activity_type: End

  flows:
    - { id: f1, from: { node: trigger }, to: { node: call_simulator } }
    - { id: f2, from: { node: call_simulator }, to: { node: respond } }
    - { id: f3, from: { node: respond }, to: { node: end } }
    - { id: f4, from: { node: respond }, to: { node: build_audit_record }, detached: true }
    - { id: f5, from: { node: build_audit_record }, to: { node: publish_audit_event } }
    - { id: f6, from: { node: publish_audit_event }, to: { node: audit_end } }
</file>

