<file path="docs/provision-pattern/025-internal-grpc-proto-contract/proto/order_runtime.proto">
syntax = "proto3";

package examples;

service OrderRuntime {
  rpc QuoteOrder(QuoteRequest) returns (QuoteResponse);
}

message QuoteRequest {
  string order_id = 1;
  string customer_id = 2;
  string currency = 3;
  int64 subtotal_cents = 4;
}

message QuoteResponse {
  string quote_id = 1;
  string status = 2;
  int64 final_price_cents = 3;
  string note = 4;
}
</file>

<file path="docs/provision-pattern/025-internal-grpc-proto-contract/README.md">
# 025 Internal gRPC Proto Contract

Runtime-local gRPC contract example for internal service traffic.

It demonstrates:

- inbound gRPC trigger registration
- typed protobuf field binding via `trigger_body.*`
- protobuf response encoding with `final_response.encoding: base64`
- runtime-local gRPC server start through `VFLOW_STATE_DIR/grpc_server.json`

```bash
VFLOW_EXAMPLES_WITH_GRPC_LIVE=1 \
  bash examples-vflow/run-all-local.sh
```

This is intended for vflow-cloud, Firecracker, and internal services. The user
workflow console should expose REST for normal workflow provisioning and
operations.
</file>

<file path="docs/provision-pattern/025-internal-grpc-proto-contract/workflow.yaml">
version: "3.0"
metadata:
  id: internal-grpc-proto-contract
  name: "Internal gRPC Proto Contract"
  description: |
    Inbound gRPC workflow used for runtime-internal service traffic. It binds
    protobuf request bytes to typed `trigger_body.*` fields, computes a quote,
    and returns raw protobuf response bytes through EndTrigger base64 decoding.
  dialect: vflow
  tags: [example, p0, grpc, protobuf, internal]

spec:
  activities:
    - id: trigger
      activity_type: Trigger
      trigger_config:
        trigger_type: grpc
        grpc:
          service: "examples.OrderRuntime"
          method: "QuoteOrder"
          body_schema: "examples.QuoteRequest"
        response_framing: length_prefixed
        end_activity: respond
      output_variable: trigger_payload

    - id: extract_request
      activity_type: Transform
      input_mappings:
        - target: quote_input
          source:
            language: v-cel
            source: '{"order_id": trigger_body.order_id, "customer_id": trigger_body.customer_id, "currency": trigger_body.currency, "subtotal_cents": trigger_body.subtotal_cents}'
      output_variable: quote_input

    - id: encode_response
      activity_type: Transform
      input_mappings:
        - target: encoded
          source:
            language: v-cel
            source: >
              proto_encode(
                {
                  "name": "QuoteResponse",
                  "fields": [
                    {"name": "quote_id",          "number": 1, "type": "string"},
                    {"name": "status",            "number": 2, "type": "string"},
                    {"name": "final_price_cents", "number": 3, "type": "int64"},
                    {"name": "note",              "number": 4, "type": "string"}
                  ]
                },
                {
                  "quote_id": "quote-" + string(quote_input.order_id),
                  "status": "quoted",
                  "final_price_cents": quote_input.subtotal_cents + 1500,
                  "note": "typed protobuf binding via trigger_body"
                }
              )
      output_variable: encoded_response

    - id: respond
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        # Byte-native response (Phase 1 of the gRPC-native devplan,
        # 2026-05-03). The `encode_response` Transform's
        # `proto_encode(...)` call writes raw bytes to
        # `encoded_response`'s handle slot via the
        # `vil_codec_protobuf` byte sidechannel; `bytes_ref` reads
        # them with zero conversion. Replaces the legacy
        # `spv1 + encoding: base64` envelope round-trip.
        final_response:
          language: bytes_ref
          source: "encoded_response"

    - id: end
      activity_type: End

  flows:
    - { id: f01, from: { node: trigger }, to: { node: extract_request } }
    - { id: f02, from: { node: extract_request }, to: { node: encode_response } }
    - { id: f03, from: { node: encode_response }, to: { node: respond } }
    - { id: f04, from: { node: respond }, to: { node: end } }

  variables:
    - { name: trigger_payload, type: object }
    - { name: quote_input, type: object }
    - { name: encoded_response, type: string }
</file>

<file path="docs/provision-pattern/026-nats-event-driven-orders/README.md">
# 026 NATS Event Driven Orders

Event-driven order workflow for runtime-local NATS integration.

It demonstrates:

- NATS trigger subscription
- NATS connector publish
- event envelope shaping with order status payloads
- skip-aware live smoke for developer/lab NATS brokers

```bash
VFLOW_EXAMPLES_WITH_NATS_WORKFLOW_LIVE=1 \
VFLOW_NATS_URL=nats://localhost:4222 \
  bash examples-vflow/run-all-local.sh
```

The live smoke requires a reachable broker and the `nats` CLI. If either is
missing, it reports `SKIP` unless strict mode is enabled.
</file>

<file path="docs/provision-pattern/026-nats-event-driven-orders/workflow.yaml">
version: "3.0"
metadata:
  id: nats-event-driven-orders
  name: "NATS Event Driven Orders"
  description: |
    Order event workflow. It subscribes to `examples.orders.created` through a
    NATS trigger, normalizes the event, publishes an accepted status event, and
    terminates without any HTTP dashboard involvement.
  dialect: vflow
  tags: [example, p0, nats, event-driven, connector, trigger]

spec:
  activities:
    - id: order_created
      activity_type: Trigger
      trigger_config:
        trigger_type: nats
        route: /examples/nats/orders/created
        nats:
          urls: "env://VFLOW_NATS_TEST_URL"
          subject: "examples.orders.created"
          queue_group: "vflow-examples-orders"
      output_variable: trigger_payload

    - id: normalize_event
      activity_type: Transform
      input_mappings:
        - target: event
          source:
            language: v-cel
            source: '{"order_id": trigger_payload.body.order_id, "customer_id": trigger_payload.body.customer_id, "currency": trigger_payload.body.currency, "amount_cents": trigger_payload.body.amount_cents, "source_subject": trigger_payload.subject}'
      output_variable: order_event

    - id: publish_status
      activity_type: Connector
      persistence: ssot
      connector_config:
        connector_ref: vastar.nats
        operation: publish
        timeout_ms: 3000
      input_mappings:
        - target: subject
          source: { language: literal, source: "examples.orders.status" }
        - target: headers
          source:
            language: v-cel
            source: '{"Nats-Event-Type": "order.accepted", "Nats-Source": "vflow.examples"}'
        - target: payload
          source:
            language: v-cel
            source: '{"status": "accepted", "order_id": order_event.order_id, "customer_id": order_event.customer_id, "currency": order_event.currency, "amount_cents": order_event.amount_cents}'
      output_variable: publish_result

    - id: end
      activity_type: End

  flows:
    - { id: f01, from: { node: order_created }, to: { node: normalize_event } }
    - { id: f02, from: { node: normalize_event }, to: { node: publish_status } }
    - { id: f03, from: { node: publish_status }, to: { node: end } }

  variables:
    - { name: trigger_payload, type: object }
    - { name: order_event, type: object }
    - { name: publish_result, type: object }
</file>

<file path="docs/provision-pattern/027-local-infra-connector-business-pack/README.md">
# 027 Local Infra Connector Business Pack

Scenario: a return-merchandise authorization workflow receives a customer
return, reserves an idempotency lock, writes service routing config, checks a
wide-row customer backend, stores evidence, drops a warehouse manifest, and
touches analytics/audit infrastructure.

This example is intentionally local/lab-infra scoped. The workflow YAML is part
of the default compile regression. Real connector execution is handled by the
skip-aware local-infra smoke:

```bash
bash examples-vflow/runtime-smoke/local-infra-connector-business-pack-smoke.sh
```

Strict mode fails if any configured connector is missing:

```bash
VFLOW_LOCAL_INFRA_STRICT=1 \
bash examples-vflow/runtime-smoke/local-infra-connector-business-pack-smoke.sh
```

Business behavior:

- Redis provides the idempotency lock for retry-safe intake.
- Etcd stores the route/config snapshot used by downstream return handling.
- Cassandra/Scylla represents a customer/account wide-row lookup.
- S3/SeaweedFS stores the evidence bundle.
- SFTP drops a manifest for a warehouse/WMS integration.
- ClickHouse is the analytics/audit backend readiness check.
- SQLite pack write shows that user-owned packs can sit beside built-in
  connector families.

Side-effect note: operator retry is still current-version retry. Any production
version of this pattern must preserve `return_id` and `idempotency_key` across
retry.
</file>

<file path="docs/provision-pattern/027-local-infra-connector-business-pack/workflow.yaml">
version: "3.0"
metadata:
  id: local-infra-connector-business-pack
  name: "Local Infra Connector Business Pack"
  description: |
    Return authorization workflow that demonstrates local/lab connector
    backends in one realistic business flow. Runtime execution is skip-aware
    because Redis, Etcd, S3/SeaweedFS, SFTP, ClickHouse, and Cassandra/Scylla
    may not all be present on a developer laptop.
  dialect: vflow
  tags: [example, p1, connectors, local-infra, business-pack]

spec:
  durability:
    enabled: true
    default_mode: journal-state

  activities:
    - id: trigger
      activity_type: Trigger
      trigger_config:
        trigger_type: webhook
        route: /examples/local-infra/returns
        webhook_config: { path: /examples/local-infra/returns, method: POST }
        response_framing: length_prefixed
        end_activity: respond
      output_variable: trigger_payload

    - id: validate_return
      activity_type: Validate
      validate_config:
        input: "$.trigger_payload.body"
        schema:
          required: [return_id, order_id, customer_id, sku, reason, idempotency_key]
          properties:
            return_id: { type: string, min_length: 3 }
            order_id: { type: string, min_length: 3 }
            customer_id: { type: string, min_length: 3 }
            sku: { type: string, min_length: 2 }
            reason: { type: string, min_length: 3 }
            idempotency_key: { type: string, min_length: 8 }
      output_variable: validated_return

    - id: normalize_return
      activity_type: Transform
      input_mappings:
        - target: return_context
          source:
            language: v-cel
            source: '{"return_id": trigger_payload.body.return_id, "order_id": trigger_payload.body.order_id, "customer_id": trigger_payload.body.customer_id, "sku": trigger_payload.body.sku, "reason": trigger_payload.body.reason, "idempotency_key": trigger_payload.body.idempotency_key, "s3_key": "returns/" + trigger_payload.body.return_id + "/evidence.json", "manifest_path": "/upload/returns/" + trigger_payload.body.return_id + ".json"}'
      output_variable: return_context

    - id: redis_idempotency_lock
      activity_type: Connector
      persistence: ssot
      description: "Retry-safe intake lock. Current-version retry must reuse the same idempotency key."
      connector_config:
        connector_ref: vastar.redis
        operation: set_ex
      input_mappings:
        - target: key
          source:
            language: v-cel
            source: '"vflow:examples:returns:idempotency:" + return_context.idempotency_key'
        - target: value
          source:
            language: v-cel
            source: '{"return_id": return_context.return_id, "status": "received"}'
        - target: ttl
          source: { language: literal, source: "86400" }
      output_variable: idempotency_lock

    - id: etcd_route_snapshot
      activity_type: Connector
      persistence: durable_strict
      connector_config:
        connector_ref: vastar.etcd
        operation: put
      input_mappings:
        - target: key
          source:
            language: v-cel
            source: '"/vflow/examples/returns/routes/" + return_context.return_id'
        - target: value
          source:
            language: v-cel
            source: '{"route": "warehouse-rma", "sku": return_context.sku, "reason": return_context.reason}'
      output_variable: route_snapshot

    - id: cassandra_customer_lookup
      activity_type: Connector
      connector_config:
        connector_ref: vastar.cassandra
        operation: select
      input_mappings:
        - target: query
          source:
            language: literal
            source: "SELECT release_version FROM system.local"
      output_variable: customer_backend

    - id: clickhouse_audit_ready
      activity_type: Connector
      connector_config:
        connector_ref: vastar.clickhouse
        operation: ping
      output_variable: analytics_ready

    - id: store_evidence_bundle
      activity_type: Connector
      persistence: ssot
      connector_config:
        connector_ref: vastar.s3
        operation: put_object
      input_mappings:
        - target: key
          source: { language: spv1, source: "$.return_context.s3_key" }
        - target: body
          source:
            language: v-cel
            source: '{"return_id": return_context.return_id, "order_id": return_context.order_id, "customer_id": return_context.customer_id, "sku": return_context.sku, "reason": return_context.reason}'
      output_variable: evidence_object

    - id: drop_warehouse_manifest
      activity_type: Connector
      persistence: ssot
      connector_config:
        connector_ref: vastar.sftp
        operation: upload
      input_mappings:
        - target: path
          source: { language: spv1, source: "$.return_context.manifest_path" }
        - target: data
          source:
            language: v-cel
            source: '{"return_id": return_context.return_id, "sku": return_context.sku, "s3_key": return_context.s3_key}'
      output_variable: warehouse_manifest

    - id: local_pack_audit
      activity_type: Connector
      connector_config:
        connector_ref: "pack://examples/hello-db/primary"
        operation: raw_query
      input_mappings:
        - target: query
          source:
            language: literal
            source: "select 'return-accepted' as event_type"
      output_variable: pack_audit

    - id: accepted_response
      activity_type: Transform
      input_mappings:
        - target: response
          source:
            language: v-cel
            source: '{"status": "accepted", "return_id": return_context.return_id, "evidence_key": return_context.s3_key, "manifest_path": return_context.manifest_path, "retry_warning": "operator retry uses current active workflow version; preserve idempotency_key"}'
      output_variable: final_response

    - id: respond
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response: { language: spv1, source: "$.final_response" }

    - id: end
      activity_type: End

  flows:
    - { id: f01, from: { node: trigger }, to: { node: validate_return } }
    - { id: f02, from: { node: validate_return }, to: { node: normalize_return } }
    - { id: f03, from: { node: normalize_return }, to: { node: redis_idempotency_lock } }
    - { id: f04, from: { node: redis_idempotency_lock }, to: { node: etcd_route_snapshot } }
    - { id: f05, from: { node: etcd_route_snapshot }, to: { node: cassandra_customer_lookup } }
    - { id: f06, from: { node: cassandra_customer_lookup }, to: { node: clickhouse_audit_ready } }
    - { id: f07, from: { node: clickhouse_audit_ready }, to: { node: store_evidence_bundle } }
    - { id: f08, from: { node: store_evidence_bundle }, to: { node: drop_warehouse_manifest } }
    - { id: f09, from: { node: drop_warehouse_manifest }, to: { node: local_pack_audit } }
    - { id: f10, from: { node: local_pack_audit }, to: { node: accepted_response } }
    - { id: f11, from: { node: accepted_response }, to: { node: respond } }
    - { id: f12, from: { node: respond }, to: { node: end } }

  variables:
    - { name: trigger_payload, type: object }
    - { name: return_context, type: object }
    - { name: final_response, type: object }
</file>

<file path="docs/provision-pattern/028-storage-and-cloud-messaging-adapters/README.md">
# 028 Storage And Cloud Messaging Adapters

Scenario: a billing runtime receives a finalized invoice, stores the canonical
archive object, mirrors it to cloud storage providers, drops a partner manifest,
and publishes downstream notifications to messaging adapters.

This example is a workflow-level contract for storage and cloud messaging
adapter shapes. It is part of the default compile regression. Live execution is
split:

```bash
bash examples-vflow/runtime-smoke/storage-cloud-messaging-adapters-smoke.sh
```

Storage behavior:

- S3/SeaweedFS stores the canonical invoice archive.
- GCS and Azure Blob show provider-specific mirror operations.
- SFTP drops a partner manifest for batch integrations.

Messaging behavior:

- NATS publishes the runtime-local event used by VFlow deployments.
- Kafka, MQTT, RabbitMQ, Pulsar, Pub/Sub, and SQS publish declarations are kept
  in one business flow so the public connector surface is visible.

Live smoke is intentionally skip-aware. S3/SeaweedFS, SFTP, and NATS can be
validated locally when endpoints are present. Cloud-provider and heavyweight
broker adapters remain provider/lab optional until credentials and simulators
are configured.
</file>

<file path="docs/provision-pattern/028-storage-and-cloud-messaging-adapters/workflow.yaml">
version: "3.0"
metadata:
  id: storage-and-cloud-messaging-adapters
  name: "Storage and Cloud Messaging Adapters"
  description: |
    Billing archive workflow that demonstrates storage adapter writes and
    downstream messaging fanout. Runtime execution is local/lab-infra scoped:
    S3/SeaweedFS, SFTP, and NATS have skip-aware local smoke coverage; GCS,
    Azure Blob, Kafka, MQTT, RabbitMQ, Pulsar, Pub/Sub, and SQS are declared as
    provider/lab connector contracts.
  dialect: vflow
  tags: [example, p1, storage, messaging, cloud-adapters]

spec:
  durability:
    enabled: true
    default_mode: journal-state

  activities:
    - id: invoice_api
      activity_type: Trigger
      trigger_config:
        trigger_type: webhook
        route: /examples/storage/invoices
        webhook_config: { path: /examples/storage/invoices, method: POST }
        response_framing: length_prefixed
        end_activity: respond
      output_variable: trigger_payload

    - id: invoice_file_event
      activity_type: Trigger
      trigger_config:
        trigger_type: s3_event
        route: /examples/storage/invoices/s3-event
        s3_event:
          bucket: "vflow-examples"
          prefix: "billing/invoices/incoming/"
      output_variable: trigger_payload

    - id: validate_invoice
      activity_type: Validate
      validate_config:
        input: "$.trigger_payload.body"
        schema:
          required: [invoice_id, tenant_id, customer_id, total_cents, currency, idempotency_key]
          properties:
            invoice_id: { type: string, min_length: 3 }
            tenant_id: { type: string, min_length: 3 }
            customer_id: { type: string, min_length: 3 }
            total_cents: { type: integer, minimum: 0 }
            currency: { type: string, min_length: 3, max_length: 3 }
            idempotency_key: { type: string, min_length: 8 }
      output_variable: validated_invoice

    - id: build_archive_context
      activity_type: Transform
      input_mappings:
        - target: archive_context
          source:
            language: v-cel
            source: '{"invoice_id": trigger_payload.body.invoice_id, "tenant_id": trigger_payload.body.tenant_id, "customer_id": trigger_payload.body.customer_id, "total_cents": trigger_payload.body.total_cents, "currency": trigger_payload.body.currency, "idempotency_key": trigger_payload.body.idempotency_key, "archive_key": "billing/" + trigger_payload.body.tenant_id + "/invoices/" + trigger_payload.body.invoice_id + ".json", "partner_manifest_path": "/upload/billing/" + trigger_payload.body.invoice_id + ".json", "event_subject": "examples.billing.invoice.archived"}'
      output_variable: archive_context

    - id: store_canonical_archive
      activity_type: Connector
      persistence: ssot
      description: "Canonical invoice archive; retry must reuse idempotency_key and archive_key."
      connector_config:
        connector_ref: vastar.s3
        operation: put_object
      input_mappings:
        - target: key
          source: { language: spv1, source: "$.archive_context.archive_key" }
        - target: body
          source:
            language: v-cel
            source: '{"invoice_id": archive_context.invoice_id, "tenant_id": archive_context.tenant_id, "customer_id": archive_context.customer_id, "total_cents": archive_context.total_cents, "currency": archive_context.currency}'
      output_variable: s3_archive

    - id: mirror_to_gcs
      activity_type: Connector
      persistence: durable_strict
      description: "Provider optional cloud storage mirror."
      connector_config:
        connector_ref: vastar.gcs
        operation: upload
      input_mappings:
        - target: key
          source: { language: spv1, source: "$.archive_context.archive_key" }
        - target: data
          source:
            language: v-cel
            source: '{"invoice_id": archive_context.invoice_id, "provider": "gcs"}'
      output_variable: gcs_mirror

    - id: mirror_to_azure_blob
      activity_type: Connector
      persistence: durable_strict
      description: "Provider optional Azure Blob mirror."
      connector_config:
        connector_ref: vastar.azure
        operation: upload_blob
      input_mappings:
        - target: blob
          source: { language: spv1, source: "$.archive_context.archive_key" }
        - target: data
          source:
            language: v-cel
            source: '{"invoice_id": archive_context.invoice_id, "provider": "azure"}'
      output_variable: azure_mirror

    - id: drop_partner_manifest
      activity_type: Connector
      persistence: ssot
      connector_config:
        connector_ref: vastar.sftp
        operation: upload
      input_mappings:
        - target: path
          source: { language: spv1, source: "$.archive_context.partner_manifest_path" }
        - target: data
          source:
            language: v-cel
            source: '{"invoice_id": archive_context.invoice_id, "archive_key": archive_context.archive_key, "customer_id": archive_context.customer_id}'
      output_variable: partner_manifest

    - id: publish_runtime_event
      activity_type: Connector
      connector_config:
        connector_ref: vastar.nats
        operation: publish
      input_mappings:
        - target: subject
          source: { language: spv1, source: "$.archive_context.event_subject" }
        - target: payload
          source:
            language: v-cel
            source: '{"invoice_id": archive_context.invoice_id, "archive_key": archive_context.archive_key, "status": "archived"}'
      output_variable: nats_event

    - id: publish_kafka_event
      activity_type: Connector
      connector_config:
        connector_ref: vastar.kafka
        operation: publish
      input_mappings:
        - target: topic
          source: { language: literal, source: "examples.billing.invoice.archived" }
        - target: payload
          source:
            language: v-cel
            source: '{"invoice_id": archive_context.invoice_id, "archive_key": archive_context.archive_key}'
      output_variable: kafka_event

    - id: publish_mqtt_event
      activity_type: Connector
      connector_config:
        connector_ref: vastar.mqtt
        operation: publish
      input_mappings:
        - target: topic
          source: { language: literal, source: "examples/billing/invoice/archived" }
        - target: payload
          source:
            language: v-cel
            source: '{"invoice_id": archive_context.invoice_id, "tenant_id": archive_context.tenant_id}'
      output_variable: mqtt_event

    - id: publish_rabbitmq_event
      activity_type: Connector
      connector_config:
        connector_ref: vastar.rabbitmq
        operation: publish
      input_mappings:
        - target: exchange
          source: { language: literal, source: "billing.events" }
        - target: routing_key
          source: { language: literal, source: "invoice.archived" }
        - target: payload
          source:
            language: v-cel
            source: '{"invoice_id": archive_context.invoice_id, "archive_key": archive_context.archive_key}'
      output_variable: rabbitmq_event

    - id: publish_pulsar_event
      activity_type: Connector
      connector_config:
        connector_ref: vastar.pulsar
        operation: publish
      input_mappings:
        - target: payload
          source:
            language: v-cel
            source: '{"invoice_id": archive_context.invoice_id, "archive_key": archive_context.archive_key}'
      output_variable: pulsar_event

    - id: publish_pubsub_event
      activity_type: Connector
      connector_config:
        connector_ref: vastar.pubsub
        operation: publish
      input_mappings:
        - target: topic
          source: { language: literal, source: "billing-invoice-archived" }
        - target: payload
          source:
            language: v-cel
            source: '{"invoice_id": archive_context.invoice_id, "archive_key": archive_context.archive_key}'
      output_variable: pubsub_event

    - id: send_sqs_event
      activity_type: Connector
      connector_config:
        connector_ref: vastar.sqs
        operation: send
      input_mappings:
        - target: body
          source:
            language: v-cel
            source: '{"invoice_id": archive_context.invoice_id, "archive_key": archive_context.archive_key, "idempotency_key": archive_context.idempotency_key}'
      output_variable: sqs_event

    - id: accepted_response
      activity_type: Transform
      input_mappings:
        - target: response
          source:
            language: v-cel
            source: '{"status": "archived", "invoice_id": archive_context.invoice_id, "archive_key": archive_context.archive_key, "partner_manifest": archive_context.partner_manifest_path, "event_subject": archive_context.event_subject}'
      output_variable: final_response

    - id: respond
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: invoice_api
        final_response: { language: spv1, source: "$.final_response" }

    - id: end
      activity_type: End

  flows:
    - { id: f01, from: { node: invoice_api }, to: { node: validate_invoice } }
    - { id: f02, from: { node: invoice_file_event }, to: { node: validate_invoice } }
    - { id: f03, from: { node: validate_invoice }, to: { node: build_archive_context } }
    - { id: f04, from: { node: build_archive_context }, to: { node: store_canonical_archive } }
    - { id: f05, from: { node: store_canonical_archive }, to: { node: mirror_to_gcs } }
    - { id: f06, from: { node: mirror_to_gcs }, to: { node: mirror_to_azure_blob } }
    - { id: f07, from: { node: mirror_to_azure_blob }, to: { node: drop_partner_manifest } }
    - { id: f08, from: { node: drop_partner_manifest }, to: { node: publish_runtime_event } }
    - { id: f09, from: { node: publish_runtime_event }, to: { node: publish_kafka_event } }
    - { id: f10, from: { node: publish_kafka_event }, to: { node: publish_mqtt_event } }
    - { id: f11, from: { node: publish_mqtt_event }, to: { node: publish_rabbitmq_event } }
    - { id: f12, from: { node: publish_rabbitmq_event }, to: { node: publish_pulsar_event } }
    - { id: f13, from: { node: publish_pulsar_event }, to: { node: publish_pubsub_event } }
    - { id: f14, from: { node: publish_pubsub_event }, to: { node: send_sqs_event } }
    - { id: f15, from: { node: send_sqs_event }, to: { node: accepted_response } }
    - { id: f16, from: { node: accepted_response }, to: { node: respond } }
