version: "3.0"
metadata:
  id: order-process
  version: 2
  name: "Order Processing v2"
  # v2 adds discount calculation before responding
  # Test without affecting live traffic:
  #   curl -X POST /workflow/provision -d @workflow-v2.yaml
  #   curl -X POST /api/orders@v2 -d '{"items":[...]}'
  # Activate v2 for all traffic:
  #   curl -X POST /workflow/order-process@v2/activate
spec:
  activities:
    - id: trigger
      activity_type: Trigger
      trigger_config:
        trigger_type: webhook
        webhook_config: { path: /api/orders, method: POST }
        response_framing: length_prefixed
        end_activity: respond
      output_variable: trigger_payload
    - id: validate
      activity_type: Transform
      input_mappings:
        - target: order
          source: { language: v-cel, source: 'trigger_payload.body' }
        - target: is_valid
          source: { language: v-cel, source: 'trigger_payload.body.total > 0 && trigger_payload.body.items.size() > 0' }
      output_variable: validated
    - id: apply_discount
      activity_type: VRule
      rule_config:
        rule_set_id: discount_rules_v2
      input_mappings:
        - target: order
          source: { language: v-cel, source: 'validated.order' }
        - target: item_count
          source: { language: v-cel, source: 'trigger_payload.body.items.size()' }
      output_variable: discounted
    - id: respond
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response: { language: v-cel, source: 'discounted' }
    - id: end
      activity_type: End
  flows:
    - { id: f1, from: { node: trigger }, to: { node: validate } }
    - { id: f2, from: { node: validate }, to: { node: apply_discount } }
    - { id: f3, from: { node: apply_discount }, to: { node: respond } }
    - { id: f4, from: { node: respond }, to: { node: end } }
</file>

<file path="docs/provision-pattern/004-parallel-join/workflow.yaml">
version: "3.0"
metadata:
  id: parallel-enrich
  name: "Parallel Data Enrichment"
  # VFlow-exclusive: Parallel fork + Join barrier
  # Fires enrich_credit and enrich_fraud concurrently, Join waits for both
spec:
  activities:
    - id: trigger
      activity_type: Trigger
      trigger_config:
        trigger_type: webhook
        webhook_config: { path: /api/enrich, method: POST }
        response_framing: length_prefixed
        end_activity: respond
      output_variable: trigger_payload
    - id: fork
      activity_type: Parallel
      parallel_config: { mode: all }
    - id: enrich_credit
      activity_type: Connector
      persistence: ssot         # P4.20: credit bureau response is authoritative
      connector_config:
        connector_ref: vastar.http
        operation: post
      input_mappings:
        - target: url
          source: { language: literal, source: "http://credit-bureau/api/check" }
        - target: body
          source: { language: v-cel, source: 'trigger_payload.body' }
      output_variable: credit_result
    - id: enrich_fraud
      activity_type: Connector
      persistence: ssot         # P4.20: fraud score is billable; don't re-call on resume
      connector_config:
        connector_ref: vastar.http
        operation: post
      input_mappings:
        - target: url
          source: { language: literal, source: "http://fraud-service/api/score" }
        - target: body
          source: { language: v-cel, source: 'trigger_payload.body' }
      output_variable: fraud_result
    - id: join
      activity_type: Join
      join_config: { mode: wait_all }
      output_variable: merged
    - id: respond
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response: { language: v-cel, source: 'merged' }
    - id: end
      activity_type: End
  flows:
    - { id: f1, from: { node: trigger }, to: { node: fork } }
    - { id: f2, from: { node: fork }, to: { node: enrich_credit } }
    - { id: f3, from: { node: fork }, to: { node: enrich_fraud } }
    - { id: f4, from: { node: enrich_credit }, to: { node: join } }
    - { id: f5, from: { node: enrich_fraud }, to: { node: join } }
    - { id: f6, from: { node: join }, to: { node: respond } }
    - { id: f7, from: { node: respond }, to: { node: end } }
</file>

<file path="docs/provision-pattern/005-vdicl-rules/workflow.yaml">
version: "3.0"
metadata:
  id: vdicl-kyc
  name: "VDICL Bytecode Rule Engine — KYC Scoring"
  # VFlow-exclusive: VDICL-compiled rule packs evaluated at 38ns/rule
  # Rule packs are pre-compiled bytecode loaded at provision time
spec:
  activities:
    - id: trigger
      activity_type: Trigger
      trigger_config:
        trigger_type: webhook
        webhook_config: { path: /api/kyc/evaluate, method: POST }
        response_framing: length_prefixed
        end_activity: respond
      output_variable: trigger_payload
    - id: identity_rules
      activity_type: VRule
      rule_config:
        rule_set_id: kyc_identity_v3
        rule_pack: "compiled/kyc_identity_v3.vdicl"
        eval_mode: bytecode
      input_mappings:
        - target: nik
          source: { language: v-cel, source: 'trigger_payload.body.nik' }
        - target: full_name
          source: { language: v-cel, source: 'trigger_payload.body.name' }
        - target: dob
          source: { language: v-cel, source: 'trigger_payload.body.date_of_birth' }
      output_variable: identity_result
    - id: risk_rules
      activity_type: VRule
      rule_config:
        rule_set_id: kyc_risk_scoring_v2
        rule_pack: "compiled/kyc_risk_v2.vdicl"
        eval_mode: bytecode
      input_mappings:
        - target: identity_score
          source: { language: v-cel, source: 'identity_result.score' }
        - target: income
          source: { language: v-cel, source: 'trigger_payload.body.monthly_income' }
        - target: employment
          source: { language: v-cel, source: 'trigger_payload.body.employment_status' }
      output_variable: risk_result
    - id: merge
      activity_type: Transform
      input_mappings:
        - target: kyc_decision
          source: { language: v-cel, source: '{"identity": identity_result, "risk": risk_result, "approved": risk_result.score >= 70}' }
      output_variable: final
    - id: respond
      activity_type: EndTrigger
      end_trigger_config:
        trigger_ref: trigger
        final_response: { language: v-cel, source: 'final.kyc_decision' }
    - id: end
      activity_type: End
  flows:
    - { id: f1, from: { node: trigger }, to: { node: identity_rules } }
    - { id: f2, from: { node: identity_rules }, to: { node: risk_rules } }
    - { id: f3, from: { node: risk_rules }, to: { node: merge } }
    - { id: f4, from: { node: merge }, to: { node: respond } }
    - { id: f5, from: { node: respond }, to: { node: end } }
</file>

